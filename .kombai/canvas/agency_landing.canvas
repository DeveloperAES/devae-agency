     <button type=\"submit\" id=\"submit-btn\" class=\"group px-12 py-5 bg-[var(--gold)] text-black font-anton text-2xl uppercase flex items-center gap-4 hover:bg-white transition-colors\" style=\"cursor:pointer\" data-kid=\"275\">\n                  Enviar Mensaje\n                  <i class=\"ti ti-arrow-right text-2xl group-hover:translate-x-2 transition-transform\" data-kid=\"276\"></i>\n                </button>\n                <span class=\"text-xs opacity-30 uppercase tracking-widest\" data-kid=\"277\">Respondo en &lt;24h</span>\n              </div>\n\n              \n              <div id=\"form-success\" class=\"hidden py-8 px-10 border border-[var(--gold)]/30 bg-[var(--gold)]/5 flex items-center gap-6\" data-kid=\"278\">\n                <i class=\"ti ti-circle-check text-4xl text-[var(--gold)]\" data-kid=\"279\"></i>\n                <div data-kid=\"280\">\n                  <p class=\"font-anton text-2xl uppercase text-[var(--gold)]\" data-kid=\"281\">¡Mensaje Recibido!</p>\n                  <p class=\"text-sm opacity-60 mt-1\" data-kid=\"282\">Me pondré en contacto contigo en menos de 24 horas.</p>\n                </div>\n              </div>\n            </form>\n          </div>\n\n        </div>\n      </div>\n    </section>\n\n    \n    <footer id=\"cta-footer\" class=\"py-32 px-6 bg-[var(--onyx)]\" data-kid=\"283\">\n      <div class=\"max-w-7xl mx-auto\" data-kid=\"284\">\n        \n        <div class=\"bg-[var(--gold)] text-black p-20 md:p-32 mb-24 relative overflow-hidden flex flex-col items-center text-center\" id=\"cta-banner\" data-kid=\"285\">\n          <div class=\"absolute inset-0 opacity-[0.05] pointer-events-none border-[40px] border-black\" data-kid=\"286\"></div>\n          <div class=\"absolute inset-20 opacity-[0.05] pointer-events-none border border-black border-dashed\" data-kid=\"287\"></div>\n          \n          <div class=\"absolute inset-0 flex items-center justify-end opacity-[0.04] pointer-events-none overflow-hidden\" data-kid=\"288\">\n            <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/maze.svg\" class=\"w-[500px] h-[500px]\" alt decoding=\"async\" loading=\"lazy\" data-kid=\"289\">\n          </div>\n          <div class=\"relative z-10\" data-kid=\"290\">\n            <span class=\"font-bold uppercase tracking-[0.5em] text-xs mb-8 block\" data-kid=\"291\">// Conexión Crítica</span>\n            <h2 class=\"font-anton text-7xl md:text-9xl uppercase mb-12 leading-none\" data-kid=\"292\">¿Listo para cruzar el puente?</h2>\n            <p class=\"max-w-2xl mx-auto text-xl font-medium mb-12 opacity-80 leading-relaxed\" data-kid=\"293\">\n              Transformamos visiones complejas en realidades digitales sólidas. Tu próximo sistema crítico comienza aquí.\n            </p>\n            <a href=\"#contact\" class=\"inline-block px-16 py-6 bg-black text-white font-anton text-4xl uppercase hover:-translate-y-2 hover:shadow-[12px_12px_0_rgba(0,0,0,0.2)] transition-all\" data-kid=\"294\">\n              Agendar Auditoría\n            </a>\n          </div>\n        </div>\n\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-4 gap-12 border-t border-white/10 pt-16 mb-16\" data-kid=\"295\">\n          <div data-kid=\"296\">\n            <div class=\"flex items-center gap-3 mb-6\" data-kid=\"297\">\n              <svg width=\"36\" height=\"24\" viewBox=\"0 0 48 32\" fill=\"none\" data-kid=\"298\">\n                <path d=\"M2 30L12 2L22 30\" stroke=\"#D4AF37\" stroke-width=\"2.5\" stroke-linecap=\"square\" fill=\"none\" data-kid=\"299\"></path>\n                <path d=\"M5 20L19 20\" stroke=\"#D4AF37\" stroke-width=\"2.5\" stroke-linecap=\"square\" data-kid=\"300\"></path>\n                <path d=\"M28 2L28 30\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"square\" data-kid=\"301\"></path>\n                <path d=\"M28 2L44 2\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"square\" data-kid=\"302\"></path>\n                <path d=\"M28 16L41 16\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"square\" data-kid=\"303\"></path>\n                <path d=\"M28 30L44 30\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"square\" data-kid=\"304\"></path>\n                <rect x=\"45\" y=\"28\" width=\"3\" height=\"3\" fill=\"#D4AF37\" data-kid=\"305\"></rect>\n              </svg>\n              <div data-kid=\"306\">\n                <div class=\"font-anton text-xl uppercase tracking-tighter leading-none\" data-kid=\"307\">Anderson <span style=\"color:var(--gold)\" data-kid=\"308\">Espinoza</span></div>\n                <div class=\"text-[8px] uppercase tracking-[0.3em] opacity-40 font-bold\" data-kid=\"309\">DevAE</div>\n              </div>\n            </div>\n            <p class=\"text-xs opacity-50 leading-relaxed uppercase tracking-[0.2em] font-bold\" data-kid=\"310\">Desarrollo Web & Arquitectura Digital<br data-kid=\"311\">Basado en la robustez técnica.</p>\n          </div>\n          <div data-kid=\"312\">\n            <h4 class=\"font-anton text-xl uppercase mb-8 text-[var(--gold)]\" data-kid=\"313\">Sitemap</h4>\n            <ul class=\"flex flex-col gap-5 text-xs uppercase tracking-widest font-bold opacity-60\" data-kid=\"314\">\n              <li data-kid=\"315\"><a href=\"#services\" class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"316\">Servicios</a></li>\n              <li data-kid=\"317\"><a href=\"#tech\" class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"318\">Ecosistema</a></li>\n              <li data-kid=\"319\"><a href=\"#portfolio\" class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"320\">Casos de Éxito</a></li>\n              <li data-kid=\"321\"><a href=\"#contact\" class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"322\">Contacto</a></li>\n            </ul>\n          </div>\n          <div data-kid=\"323\">\n            <h4 class=\"font-anton text-xl uppercase mb-8 text-[var(--gold)]\" data-kid=\"324\">Redes</h4>\n            <ul class=\"flex flex-col gap-5 text-xs uppercase tracking-widest font-bold opacity-60\" data-kid=\"325\">\n              <li data-kid=\"326\"><a href=\"#\" class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"327\">LinkedIn</a></li>\n              <li data-kid=\"328\"><a href=\"#\" class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"329\">Twitter / X</a></li>\n              <li data-kid=\"330\"><a href=\"#\" class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"331\">GitHub</a></li>\n              <li data-kid=\"332\"><a href=\"#\" class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"333\">Instagram</a></li>\n            </ul>\n          </div>\n          <div data-kid=\"334\">\n            <h4 class=\"font-anton text-xl uppercase mb-8 text-[var(--gold)]\" data-kid=\"335\">Contacto</h4>\n            <ul class=\"flex flex-col gap-5 text-xs uppercase tracking-widest font-bold opacity-60\" data-kid=\"336\">\n              <li data-kid=\"337\">hola@devae.dev</li>\n              <li data-kid=\"338\">Anderson Espinoza</li>\n              <li data-kid=\"339\">Latinoamérica · Global</li>\n            </ul>\n          </div>\n        </div>\n\n        <div class=\"flex flex-col md:flex-row justify-between items-center gap-6 pt-12 border-t border-white/5 text-[10px] uppercase tracking-[0.5em] font-bold opacity-30\" data-kid=\"340\">\n          <span data-kid=\"341\">&copy; 2025 Anderson Espinoza · DevAE</span>\n          <div class=\"flex gap-12\" data-kid=\"342\">\n            <span class=\"hover:text-white cursor-pointer transition-colors\" data-kid=\"343\">Privacidad</span>\n            <span class=\"hover:text-white cursor-pointer transition-colors\" data-kid=\"344\">Términos</span>\n          </div>\n        </div>\n      </div>\n    </footer>\n\n  </div>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"345\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"346\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/TextPlugin.min.js\" data-kid=\"347\"></script>\n<script type=\"module\" data-kid=\"348\">\n  import { animate, scroll, stagger, inView } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\";\n\n  gsap.registerPlugin(ScrollTrigger, TextPlugin);\n\n  /* ─── Hero ─── */\n  gsap.from(\".reveal-hero\", {\n    autoAlpha: 0, y: 30, duration: 1,\n    stagger: 0.1, ease: \"power4.out\", delay: 0.3\n  });\n\n  // Counter animation\n  const cObj = { v: 200 };\n  gsap.to(cObj, {\n    v: 120, duration: 3, ease: \"power4.out\",\n    onUpdate: () => { document.getElementById('latency-counter').innerText = Math.floor(cObj.v); },\n    scrollTrigger: { trigger: \"#dashboard-bento\", start: \"top center\" }\n  });\n\n  /* ─── Headline typewriter effect ─── */\n  gsap.to(\"#hero-headline\", {\n    delay: 1.5, duration: 0,\n    onComplete: () => {\n      const target = document.getElementById('hero-headline');\n      const original = \"Construimos\\nla Web\";\n      // Add blinking cursor after initial load — already in HTML\n    }\n  });\n\n  /* ─── Services reveal ─── */\n  gsap.from(\".reveal-service\", {\n    scrollTrigger: { trigger: \"#modular-tiles\", start: \"top 80%\" },\n    autoAlpha: 0, y: 40, duration: 0.8, stagger: 0.1, ease: \"power3.out\"\n  });\n\n  /* ─── Ledger stagger from left ─── */\n  gsap.from(\".reveal-ledger\", {\n    scrollTrigger: { trigger: \"#capability-ledger\", start: \"top 70%\" },\n    autoAlpha: 0, x: -40, duration: 0.9, stagger: 0.15, ease: \"power2.out\"\n  });\n\n  /* ─── Portfolio reveal ─── */\n  gsap.from(\".reveal-portfolio\", {\n    scrollTrigger: { trigger: \"#filterable-grid\", start: \"top 80%\" },\n    autoAlpha: 0, y: 40, duration: 0.8, stagger: 0.1, ease: \"power3.out\"\n  });\n\n  // Clip-path reveal for portfolio images via motionjs\n  document.querySelectorAll('.portfolio-reveal').forEach(img => {\n    inView(img, () => {\n      animate(img, { clipPath: 'inset(0 0 0 0)' }, { duration: 1.2, easing: [0.22,1,0.36,1], delay: 0.2 });\n    });\n    const parent = img.closest('.group');\n    if (parent) {\n      parent.addEventListener('pointerenter', () => {\n        animate(img, { scale: 1.05, filter: 'grayscale(0%)' }, { duration: 0.6 });\n      });\n      parent.addEventListener('pointerleave', () => {\n        animate(img, { scale: 1.0, filter: 'grayscale(100%)' }, { duration: 0.4 });\n      });\n    }\n  });\n\n  /* ─── Contact section reveal ─── */\n  gsap.from(\".reveal-contact\", {\n    scrollTrigger: { trigger: \"#contact\", start: \"top 75%\" },\n    autoAlpha: 0, y: 50, duration: 1, stagger: 0.15, ease: \"power3.out\"\n  });\n\n  /* ─── CTA Banner entrance ─── */\n  gsap.from(\"#cta-banner\", {\n    scrollTrigger: { trigger: \"#cta-footer\", start: \"top 80%\" },\n    autoAlpha: 0, scale: 0.97, duration: 1.2, ease: \"power4.out\"\n  });\n\n  /* ─── Budget radio interactive ─── */\n  document.querySelectorAll('.budget-option').forEach(label => {\n    label.addEventListener('click', () => {\n      document.querySelectorAll('.budget-option').forEach(l => {\n        l.style.borderColor = 'rgba(255,255,255,0.1)';\n        l.style.color = 'rgba(255,255,255,0.4)';\n      });\n      label.style.borderColor = 'var(--gold)';\n      label.style.color = 'var(--gold)';\n    });\n  });\n\n  /* ─── Contact form submit ─── */\n  document.getElementById('contact-form').addEventListener('submit', e => {\n    e.preventDefault();\n    const btn = document.getElementById('submit-btn');\n    const successEl = document.getElementById('form-success');\n    animate(btn, { scale: [1, 0.95, 1.02, 1] }, { duration: 0.4 });\n    setTimeout(() => {\n      btn.closest('form').querySelector('button').style.display = 'none';\n      successEl.classList.remove('hidden');\n      animate(successEl, { opacity: [0,1], y: [20,0] }, { duration: 0.6 });\n    }, 500);\n  });\n\n  /* ─── Scroll-linked nav opacity ─── */\n  const nav = document.querySelector('nav');\n  scroll(({ y }) => {\n    nav.style.background = y.current > 80\n      ? 'rgba(17,17,17,0.97)'\n      : 'linear-gradient(to bottom,rgba(17,17,17,0.95) 0%,transparent 100%)';\n  });\n\n</script>\n",
