      "html": "\n<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n:root {\n  --bg: #080808;\n  --surface: #111111;\n  --surface2: #181818;\n  --border: #222222;\n  --border2: #2a2a2a;\n  --text: #ffffff;\n  --muted: #555555;\n  --muted2: #888888;\n  --accent: #ffffff;\n}\n\nbody {\n  background: var(--bg);\n  color: var(--text);\n  font-family: 'Inter', sans-serif;\n  margin: 0;\n  overflow-x: clip;\n  -webkit-font-smoothing: antialiased;\n}\n\nh1,h2,h3,h4,h5 { font-family: 'Syne', sans-serif; }\n\n/* Animated word */\n.word-rotate { display: inline-block; overflow: hidden; height: 1.15em; vertical-align: bottom; }\n.word-rotate-inner { display: flex; flex-direction: column; animation: wordRotate 4.5s ease-in-out infinite; }\n@keyframes wordRotate {\n  0%,20%    { transform: translateY(0%); }\n  33%,53%   { transform: translateY(-33.33%); }\n  66%,86%   { transform: translateY(-66.66%); }\n  100%      { transform: translateY(0%); }\n}\n\n/* Ticker */\n@keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }\n.ticker-track { display: flex; width: max-content; animation: ticker 18s linear infinite; }\n.ticker-track:hover { animation-play-state: paused; }\n\n/* Fade in up */\n.fade-up { opacity: 0; transform: translateY(24px); }\n\n/* Service card hover */\n.svc-card { border: 1px solid var(--border); }\n.svc-card:hover { border-color: var(--border2); background: var(--surface2); }\n\n/* Stat counter */\n.stat-num { font-family: 'Syne', sans-serif; font-weight: 800; }\n\n/* Pricing */\n.price-card { border: 1px solid var(--border); }\n.price-card.featured { border-color: #ffffff20; background: var(--surface2); }\n\n/* FAQ accordion */\n.faq-answer { max-height: 0; overflow: hidden; }\n.faq-answer.open { max-height: 300px; }\n.faq-btn.open .faq-icon { transform: rotate(45deg); }\n\n/* Contact input */\n.c-input {\n  background: transparent;\n  border: none;\n  border-bottom: 1px solid var(--border2);\n  color: white;\n  font-family: 'Inter', sans-serif;\n  font-size: 0.875rem;\n  padding: 14px 0;\n  width: 100%;\n  outline: none;\n}\n.c-input::placeholder { color: var(--muted); }\n.c-input:focus { border-bottom-color: rgba(255,255,255,0.5); }\n\n/* Scroll reveal */\n[data-reveal] { opacity: 0; transform: translateY(20px); }\n</style>\n\n\n<nav style=\"position:fixed;top:0;left:0;width:100%;z-index:50;padding:20px 48px;display:flex;justify-content:space-between;align-items:center;background:rgba(8,8,8,0.9);backdrop-filter:blur(12px);border-bottom:1px solid transparent;\" id=\"main-nav\" data-kid=\"1\">\n  <div style=\"font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem;letter-spacing:-0.02em;\" data-kid=\"2\">\n    Anderson<span style=\"color:var(--muted)\" data-kid=\"3\">Espinoza</span>\n  </div>\n  <div style=\"display:flex;gap:32px;align-items:center;font-size:0.75rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted2);\" data-kid=\"4\">\n    <a href=\"#servicios\" style=\"color:inherit;text-decoration:none;hover:color:white\" data-kid=\"5\">Servicios</a>\n    <a href=\"#sobre-mi\" style=\"color:inherit;text-decoration:none;\" data-kid=\"6\">Sobre mí</a>\n    <a href=\"#clientes\" style=\"color:inherit;text-decoration:none;\" data-kid=\"7\">Clientes</a>\n    <a href=\"#precios\" style=\"color:inherit;text-decoration:none;\" data-kid=\"8\">Precios</a>\n    <a href=\"#contacto\" style=\"padding:10px 24px;border:1px solid var(--border2);color:white;text-decoration:none;font-size:0.75rem;letter-spacing:0.08em;text-transform:uppercase;\" data-kid=\"9\">Contacto</a>\n  </div>\n</nav>\n\n\n<section id=\"hero\" style=\"min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:120px 48px 80px;position:relative;overflow:hidden;\" data-kid=\"10\">\n  \n  <div style=\"position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px);background-size:64px 64px;pointer-events:none;\" data-kid=\"11\"></div>\n\n  <div style=\"max-width:1100px;position:relative;z-index:1;\" data-kid=\"12\">\n    <div style=\"display:inline-flex;align-items:center;gap:10px;padding:6px 14px;border:1px solid var(--border2);border-radius:99px;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.15em;color:var(--muted2);margin-bottom:48px;\" class=\"fade-up\" id=\"hero-tag\" data-kid=\"13\">\n      <span style=\"width:6px;height:6px;border-radius:50%;background:#4ade80;display:inline-block;animation:ping 2s infinite;\" data-kid=\"14\"></span>\n      Disponible para proyectos\n    </div>\n\n    <h1 style=\"font-family:'Syne',sans-serif;font-size:clamp(3.5rem,8vw,7.5rem);font-weight:800;line-height:1;letter-spacing:-0.03em;margin:0 0 24px;\" class=\"fade-up\" id=\"hero-h1\" data-kid=\"15\">\n      Te ayudo a\n      <span style=\"display:block;color:var(--muted);\" data-kid=\"16\">\n        <span class=\"word-rotate\" data-kid=\"17\">\n          <span class=\"word-rotate-inner\" data-kid=\"18\">\n            <span data-kid=\"19\">crear</span>\n            <span data-kid=\"20\">construir</span>\n            <span data-kid=\"21\">escalar</span>\n          </span>\n        </span>\n      </span>\n      tu web\n    </h1>\n\n    <p style=\"font-size:1.15rem;color:var(--muted2);max-width:560px;line-height:1.7;margin:0 0 48px;\" class=\"fade-up\" id=\"hero-sub\" data-kid=\"22\">\n      Desarrollo webs en WordPress que atraen clientes, generan ventas y destacan sobre la competencia. Landing pages, e-commerce y sistemas a medida.\n    </p>\n\n    <div style=\"display:flex;gap:16px;align-items:center;\" class=\"fade-up\" id=\"hero-cta\" data-kid=\"23\">\n      <a href=\"#contacto\" style=\"padding:16px 36px;background:white;color:black;font-family:'Syn