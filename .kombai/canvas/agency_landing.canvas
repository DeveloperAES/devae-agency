9\">Clientes satisfechos</div>\n        </div>\n        <div style=\"background:var(--bg);padding:36px;text-align:center;\" data-kid=\"130\">\n          <div style=\"font-family:'Syne',sans-serif;font-size:2.5rem;font-weight:800;\" data-kid=\"131\">3+</div>\n          <div style=\"font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);margin-top:8px;\" data-kid=\"132\">Años de experiencia</div>\n        </div>\n        <div style=\"background:var(--bg);padding:36px;text-align:center;\" data-kid=\"133\">\n          <div style=\"font-family:'Syne',sans-serif;font-size:2.5rem;font-weight:800;\" data-kid=\"134\">WP</div>\n          <div style=\"font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);margin-top:8px;\" data-kid=\"135\">Especialización</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section id=\"precios\" style=\"padding:120px 48px;\" data-kid=\"136\">\n  <div style=\"max-width:1100px;margin:0 auto;\" data-kid=\"137\">\n    <div data-reveal style=\"text-align:center;margin-bottom:64px;\" data-kid=\"138\">\n      <span style=\"font-size:0.7rem;text-transform:uppercase;letter-spacing:0.2em;color:var(--muted);display:block;margin-bottom:16px;\" data-kid=\"139\">Inversión</span>\n      <h2 style=\"font-size:clamp(2rem,4vw,3rem);font-weight:800;letter-spacing:-0.03em;margin:0;\" data-kid=\"140\">Precios Transparentes</h2>\n    </div>\n\n    <div style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:24px;\" data-reveal data-kid=\"141\">\n      \n      <div class=\"price-card\" style=\"padding:40px;display:flex;flex-direction:column;gap:24px;\" data-kid=\"142\">\n        <div data-kid=\"143\">\n          <h3 style=\"font-size:1.25rem;font-weight:700;margin:0 0 8px;\" data-kid=\"144\">Página Informativa</h3>\n          <p style=\"font-size:0.8rem;color:var(--muted);margin:0;\" data-kid=\"145\">Sobre tu negocio o servicio</p>\n        </div>\n        <div style=\"padding:24px 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border);\" data-kid=\"146\">\n          <span style=\"font-family:'Syne',sans-serif;font-size:2.5rem;font-weight:800;\" data-kid=\"147\">$399</span>\n          <span style=\"color:var(--muted);font-size:0.875rem;\" data-kid=\"148\"> USD</span>\n        </div>\n        <ul style=\"list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:12px;font-size:0.8rem;color:var(--muted2);\" data-kid=\"149\">\n          <li style=\"display:flex;gap:10px;align-items:center;\" data-kid=\"150\"><i class=\"ti ti-check\" style=\"color:white;font-size:0.875rem;\" data-kid=\"151\"></i> Diseño profesional</li>\n          <li style=\"display:flex;gap:10px;align-items:center;\" data-kid=\"152\"><i class=\"ti ti-check\" style=\"color:white;font-size:0.875rem;\" data-kid=\"153\"></i> Diseño Responsive</li>\n          <li style=\"display:flex;gap:10px;align-items:center;\" data-kid=\"154\"><i class=\"ti ti-check\" style=\"color:white;font-size:0.875rem;\" data-kid=\"155\"></i> Formulario de contacto</li>\n          <li style=\"display:flex;gap:10px;align-items:center;\" data-kid=\"156\"><i class=\"ti ti-check\" style=\"color:white;font-size:0.875rem;\" data-kid=\"157\"></i> Hosting y dominio</li>\n          <li style=\"display:flex;gap:10px;align-items:center;\" data-kid=\"158\"><i class=\"ti ti-check\" style=\"color:white;font-size:0.875rem;\" data-kid=\"159\"></i> 30 días de garantía</li>\n        </ul>\n        <a href=\"#contacto\" style=\"display:block;text-align:center;padding:14px;border:1px solid var(--border2);color:var(--muted2);font-size:0.8rem;text-transform:uppercase;letter-spacing:0.08em;text-decoration:none;margin-top:auto;\" data-kid=\"160\">Contratar ahora</a>\n      </div>\n\n      \n      <div class=\"price-card featured\" style=\"padding:40px;display:flex;flex-direction:column;gap:24px;position:relative;\" data-kid=\"161\">\n        <div style=\"position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:white;color:black;font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;padding:4px 16px;white-space:nowrap;\" data-kid=\"162\">Más contratado</div>\n        <div data-kid=\"163\">\n          <h3 style=\"font-size:1.25rem;font-weight:700;margin:0 0 8px;\" data-kid=\"164\">Landing Page</h3>\n          <p style=\"font-size:0.8rem;color:var(--muted);margin:0;\" data-kid=\"165\">Diseño único + animaciones</p>\n        </div>\n        <div style=\"padding:24px 0;border-top:1px solid var(--border2);border-bottom:1px solid var(--border2);\" data-kid=\"166\">\n          <span style=\"font-family:'Syne',sans-serif;font-size:2.5rem;font-weight:800;\" data-kid=\"167\">$799</span>\n          <span style=\"color:var(--muted);font-size:0.875rem;\" data-kid=\"168\"> USD</span>\n        </div>\n        <ul style=\"list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:12px;font-size:0.8rem;color:var(--muted2);\" data-kid=\"169\">\n          <li style=\"display:flex;gap:10px;align-items:center;\" data-kid=\"170\"><i class=\"ti ti-check\" style=\"color:white;font-size:0.875rem;\" data-kid=\"171\"></i> Diseño único</li>\n          <li style=\"display:flex;gap:10px;align-items:center;\" data-kid=\"172\"><i class=\"ti ti-check\" style=\"color:white;font-size:0.875rem;\" data-kid=\"173\"></i> Animaciones incluidas</li>\n          <li style=\"display:flex;gap:10px;align-items:center;\" data-kid=\"174\"><i class=\"ti ti-check\" style=\"color:white;font-size:0.875rem;\" data-kid=\"175\"></i> Hasta 4 secciones extra</li>\n          <li style=\"display:flex;gap:10px;align-items:center;\" data-kid=\"176\"><i class=\"ti ti-check\" style=\"color:white;font-size:0.875rem;\" data-kid=\"177\"></i> Integración con RRSS</li>\n          <li style=\"display:flex;gap:10px;align-items:center;\" data-kid=\"178\"><i class=\"ti ti-check\" style=\"color:white;font-size:0.875rem;\" data-kid=\"179\"></i> 60 días de garantía</li>\n        </ul>\n        <a href=\"#contacto\" style=\"display:block;text-align:center;padding:14px;background:white;color:black;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;text-decoration:none;margin-top:auto;\" data-kid=\"180\">Contratar ahora</a>\n      </div>\n\n      \n      <div class=\"price-card\" style=\"padding:40px;display:flex;flex-direction:column;gap:24px;\" data-kid=\"181\">\n        <div data-kid=\"182\">\n          <h3 style=\"font-size:1.25rem;font-weight:700;margin:0 0 8px;\" data-kid=\"183\">Tienda Online</h3>\n          <p style=\"font-size:0.8rem;color:var(--muted);margin:0;\" data-kid=\"184\">E-commerce con WooCommerce</p>\n        </div>\n        <div style=\"padding:24px 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border);\" data-kid=\"185\">\n          <span style=\"font-family:'Syne',sans-serif;font-size:2.5rem;font-weight:800;\" data-kid=\"186\">$1.299</span>\n          <span style=\"color:var(--muted);font-size:0.875rem;\" data-kid=\"187\"> USD</span>\n        </div>\n        <ul style=\"list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:12px;font-size:0.8rem;color:var(--muted2);\" data-kid=\"188\">\n          <li style=\"display:flex;gap:10px;align-items:center;\" data-kid=\"189\"><i class=\"ti ti-check\" style=\"color:white;font-size:0.875rem;\" data-kid=\"190\"></i> Diseño personalizado</li>\n          <li style=\"display:flex;gap:10px;align-items:center;\" data-kid=\"191\"><i class=\"ti ti-check\" style=\"color:white;font-size:0.875rem;\" data-kid=\"192\"></i> Ingreso de 50 productos</li>\n          <li style=\"display:flex;gap:10px;align-items:center;\" data-kid=\"193\"><i class=\"ti ti-check\" style=\"color:white;font-size:0.875rem;\" data-kid=\"194\"></i> SEO para productos</li>\n          <li style=\"display:flex;gap:10px;align-items:center;\" data-kid=\"195\"><i class=\"ti ti-check\" style=\"color:white;font-size:0.875rem;\" data-kid=\"196\"></i> Pasarela de pagos</li>\n          <li style=\"display:flex;gap:10px;align-items:center;\" data-kid=\"197\"><i class=\"ti ti-check\" style=\"color:white;font-size:0.875rem;\" data-kid=\"198\"></i> 90 días de garantía</li>\n        </ul>\n        <a href=\"#contacto\" style=\"display:block;text-align:center;padding:14px;border:1px solid var(--border2);color:var(--muted2);font-size:0.8rem;text-transform:uppercase;letter-spacing:0.08em;text-decoration:none;margin-top:auto;\" data-kid=\"199\">Contratar ahora</a>\n      </div>\n    </div>\n\n    <p style=\"text-align:center;font-size:0.75rem;color:var(--muted);margin-top:32px;\" data-reveal data-kid=\"200\">El precio incluye el primer año de hosting y dominio. Pago 50% al inicio / 50% al finalizar.</p>\n  </div>\n</section>\n\n\n<section style=\"padding:120px 48px;background:var(--surface);border-top:1px solid var(--border);\" data-kid=\"201\">\n  <div style=\"max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;\" data-kid=\"202\">\n\n    \n    <div id=\"faq\" data-reveal data-kid=\"203\">\n      <span style=\"font-size:0.7rem;text-transform:uppercase;letter-spacing:0.2em;color:var(--muted);display:block;margin-bottom:24px;\" data-kid=\"204\">Preguntas frecuentes</span>\n      <h2 style=\"font-size:clamp(1.8rem,3vw,2.5rem);font-weight:800;letter-spacing:-0.03em;margin:0 0 48px;\" data-kid=\"205\">Resolvemos tus dudas</h2>\n\n      <div id=\"faq-list\" style=\"display:flex;flex-direction:column;border-top:1px solid var(--border);\" data-kid=\"206\">\n        <div class=\"faq-item\" style=\"border-bottom:1px solid var(--border);\" data-kid=\"207\">\n          <button class=\"faq-btn\" style=\"width:100%;display:flex;justify-content:space-between;align-items:center;padding:24px 0;background:transparent;border:none;color:white;cursor:pointer;text-align:left;font-family:'Syne',sans-serif;font-size:0.95rem;font-weight:600;\" data-kid=\"208\">\n            ¿Cuánto tiempo demora el desarrollo?\n            <i class=\"ti ti-plus faq-icon\" style=\"font-size:1rem;color:var(--muted);flex-shrink:0;margin-left:16px;\" data-kid=\"209\"></i>\n          </button>\n          <div class=\"faq-answer\" style=\"overflow:hidden;max-height:0;\" data-kid=\"210\">\n            <p style=\"font-size:0.875rem;color:var(--muted2);line-height:1.7;padding-bottom:24px;margin:0;\" data-kid=\"211\">El plazo máximo es 30 días hábiles. En la mayoría de casos la entrega es en 7 a 14 días hábiles.</p>\n          </div>\n        </div>\n        <div class=\"faq-item\" style=\"border-bottom:1px solid var(--border);\" data-kid=\"212\">\n          <button class=\"faq-btn\" style=\"width:100%;display:flex;justify-content:space-between;align-items:center;padding:24px 0;background:transparent;border:none;color:white;cursor:pointer;text-align:left;font-family:'Syne',sans-serif;font-size:0.95rem;font-weight:600;\" data-kid=\"213\">\n            ¿Cómo es la modalidad de pago?\n            <i class=\"ti ti-plus faq-icon\" style=\"font-size:1rem;color:var(--muted);flex-shrink:0;margin-left:16px;\" data-kid=\"214\"></i>\n          </button>\n          <div class=\"faq-answer\" style=\"overflow:hidden;max-height:0;\" data-kid=\"215\">\n            <p style=\"font-size:0.875rem;color:var(--muted2);line-height:1.7;padding-bottom:24px;margin:0;\" data-kid=\"216\">Se paga el 50% al iniciar el proyecto y el 50% restante al entregar la web terminada.</p>\n          </div>\n        </div>\n        <div class=\"faq-item\" style=\"border-bottom:1px solid var(--border);\" data-kid=\"217\">\n          <button class=\"faq-btn\" style=\"width:100%;display:flex;justify-content:space-between;align-items:center;padding:24px 0;background:transparent;border:none;color:white;cursor:pointer;text-align:left;font-family:'Syne',sans-serif;font-size:0.95rem;font-weight:600;\" data-kid=\"218\">\n            ¿La web tendrá mantenimiento?\n            <i class=\"ti ti-plus faq-icon\" style=\"font-size:1rem;color:var(--muted);flex-shrink:0;margin-left:16px;\" data-kid=\"219\"></i>\n          </button>\n          <div class=\"faq-answer\" style=\"overflow:hidden;max-height:0;\" data-kid=\"220\">\n            <p style=\"font-size:0.875rem;color:var(--muted2);line-height:1.7;padding-bottom:24px;margin:0;\" data-kid=\"221\">El mantenimiento está incluido gratis según los días del plan. Después, hay planes opcionales de mantenimiento mensual.</p>\n          </div>\n        </div>\n        <div class=\"faq-item\" style=\"border-bottom:1px solid var(--border);\" data-kid=\"222\">\n          <button class=\"faq-btn\" style=\"width:100%;display:flex;justify-content:space-between;align-items:center;padding:24px 0;background:transparent;border:none;color:white;cursor:pointer;text-align:left;font-family:'Syne',sans-serif;font-size:0.95rem;font-weight:600;\" data-kid=\"223\">\n            ¿Qué cubre la garantía?\n            <i class=\"ti ti-plus faq-icon\" style=\"font-size:1rem;color:var(--muted);flex-shrink:0;margin-left:16px;\" data-kid=\"224\"></i>\n          </button>\n          <div class=\"faq-answer\" style=\"overflow:hidden;max-height:0;\" data-kid=\"225\">\n            <p style=\"font-size:0.875rem;color:var(--muted2);line-height:1.7;padding-bottom:24px;margin:0;\" data-kid=\"226\">La garantía cubre ajustes de información y correcciones post-entrega sin costo adicional durante el período del plan.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div id=\"contacto\" data-reveal data-kid=\"227\">\n      <span style=\"font-size:0.7rem;text-transform:uppercase;letter-spacing:0.2em;color:var(--muted);display:block;margin-bottom:24px;\" data-kid=\"228\">Contacto</span>\n      <h2 style=\"font-size:clamp(1.8rem,3vw,2.5rem);font-weight:800;letter-spacing:-0.03em;margin:0 0 48px;\" data-kid=\"229\">¿Necesitas cotizar algo?</h2>\n\n      <form id=\"contact-form\" style=\"display:flex;flex-direction:column;gap:28px;\" data-kid=\"230\">\n        <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:20px;\" data-kid=\"231\">\n          <div data-kid=\"232\">\n            <label style=\"font-size:0.65rem;text-transform:uppercase;letter-spacing:0.15em;color:var(--muted);display:block;margin-bottom:8px;\" data-kid=\"233\">Nombre</label>\n            <input type=\"text\" class=\"c-input\" placeholder=\"Tu nombre\" data-kid=\"234\">\n          </div>\n          <div data-kid=\"235\">\n            <label style=\"font-size:0.65rem;text-transform:uppercase;letter-spacing:0.15em;color:var(--muted);display:block;margin-bottom:8px;\" data-kid=\"236\">WhatsApp</label>\n            <input type=\"tel\" class=\"c-input\" placeholder=\"+56 9 XXXX XXXX\" data-kid=\"237\">\n          </div>\n        </div>\n        <div data-kid=\"238\">\n          <label style=\"font-size:0.65rem;text-transform:uppercase;letter-spacing:0.15em;color:var(--muted);display:block;margin-bottom:8px;\" data-kid=\"239\">Correo electrónico</label>\n          <input type=\"email\" class=\"c-input\" placeholder=\"tu@email.com\" data-kid=\"240\">\n        </div>\n        <div data-kid=\"241\">\n          <label style=\"font-size:0.65rem;text-transform:uppercase;letter-spacing:0.15em;color:var(--muted);display:block;margin-bottom:8px;\" data-kid=\"242\">Mensaje o duda</label>\n          <textarea class=\"c-input\" rows=\"4\" placeholder=\"Cuéntame sobre tu proyecto...\" style=\"resize:none;\" data-kid=\"243\"></textarea>\n        </div>\n        <button type=\"submit\" style=\"width:100%;padding:16px;background:white;color:black;font-family:'Syne',sans-serif;font-weight:700;font-size:0.85rem;text-transform:uppercase;letter-spacing:0.1em;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;\" data-kid=\"244\">\n          Enviar mensaje <i class=\"ti ti-send\" data-kid=\"245\"></i>\n        </button>\n        <div id=\"form-ok\" style=\"display:none;text-align:center;padding:16px;border:1px solid rgba(74,222,128,0.3);background:rgba(74,222,128,0.05);font-size:0.875rem;color:#4ade80;\" data-kid=\"246\">\n          ✓ Mensaje enviado. Te respondo en menos de 24h.\n        </div>\n      </form>\n    </div>\n\n  </div>\n</section>\n\n\n<footer style=\"padding:64px 48px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:24px;\" data-kid=\"247\">\n  <div data-kid=\"248\">\n    <div style=\"font-family:'Syne',sans-serif;font-weight:800;font-size:1rem;letter-spacing:-0.02em;margin-bottom:8px;\" data-kid=\"249\">Anderson<span style=\"color:var(--muted);\" data-kid=\"250\">Espinoza</span></div>\n    <p style=\"font-size:0.75rem;color:var(--muted);margin:0;\" data-kid=\"251\">© 2025 · Desarrollo Web WordPress · Latinoamérica</p>\n  </div>\n  <div style=\"display:flex;gap:16px;\" data-kid=\"252\">\n    <a href=\"#\" style=\"width:40px;height:40px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;color:var(--muted2);text-decoration:none;\" data-kid=\"253\"><i class=\"ti ti-brand-linkedin\" data-kid=\"254\"></i></a>\n    <a href=\"#\" style=\"width:40px;height:40px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;color:var(--muted2);text-decoration:none;\" data-kid=\"255\"><i class=\"ti ti-brand-github\" data-kid=\"256\"></i></a>\n    <a href=\"#\" style=\"width:40px;height:40px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;color:var(--muted2);text-decoration:none;\" data-kid=\"257\"><i class=\"ti ti-brand-instagram\" data-kid=\"258\"></i></a>\n    <a href=\"#\" style=\"width:40px;height:40px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;color:var(--muted2);text-decoration:none;\" data-kid=\"259\"><i class=\"ti ti-brand-x\" data-kid=\"260\"></i></a>\n  </div>\n</footer>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"261\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"262\"></script>\n<script data-kid=\"263\">\ngsap.registerPlugin(ScrollTrigger);\n\n/* ── Hero fade-up ── */\ngsap.from('#hero-tag',  { autoAlpha:0, y:20, duration:.8, delay:.2, ease:'power3.out' });\ngsap.from('#hero-h1',   { autoAlpha:0, y:30, duration:.9, delay:.35, ease:'power3.out' });\ngsap.from('#hero-sub',  { autoAlpha:0, y:20, duration:.8, delay:.5, ease:'power3.out' });\ngsap.from('#hero-cta',  { autoAlpha:0, y:20, duration:.8, delay:.65, ease:'power3.out' });\ngsap.from('#hero-stats',{ autoAlpha:0, y:20, duration:.8, delay:.8, ease:'power3.out' });\n\n/* ── Scroll reveal ── */\ndocument.querySelectorAll('[data-reveal]').forEach(el => {\n  gsap.from(el, {\n    scrollTrigger: { trigger: el, start: 'top 85%' },\n    autoAlpha: 0, y: 24, duration: .8, ease: 'power3.out'\n  });\n});\n\n/* ── Counter animation ── */\nfunction animateCount(el) {\n  const target = parseInt(el.getAttribute('data-target'));\n  gsap.to({ v: 0 }, {\n    v: target,\n    duration: 2,\n    ease: 'power2.out',\n    onUpdate: function() { el.textContent = Math.floor(this.targets()[0].v) + '+'; },\n    scrollTrigger: { trigger: el, start: 'top 80%' }\n  });\n}\ndocument.querySelectorAll('.count-up').forEach(animateCount);\n\n/* ── Nav border on scroll ── */\nwindow.addEventListener('scroll', () => {\n  document.getElementById('main-nav').style.borderBottomColor = window.scrollY > 60 ? 'var(--border)' : 'transparent';\n});\n\n/* ── FAQ accordion ── */\ndocument.querySelectorAll('.faq-btn').forEach(btn => {\n  btn.addEventListener('click', () => {\n    const item = btn.closest('.faq-item');\n    const answer = item.querySelector('.faq-answer');\n    const isOpen = answer.style.maxHeight !== '0px' && answer.style.maxHeight !== '';\n    // close all\n    document.querySelectorAll('.faq-answer').forEach(a => { a.style.maxHeight = '0px'; a.style.paddingBottom = '0'; });\n    document.querySelectorAll('.faq-btn .faq-icon').forEach(i => { i.style.transform = ''; i.style.color = 'var(--muted)'; });\n    if (!isOpen) {\n      answer.style.maxHeight = answer.scrollHeight + 'px';\n      btn.querySelector('.faq-icon').style.transform = 'rotate(45deg)';\n      btn.querySelector('.faq-icon').style.color = 'white';\n    }\n  });\n});\n\n/* ── Contact form ── */\ndocument.getElementById('contact-form').addEventListener('submit', e => {\n  e.preventDefault();\n  const btn = e.target.querySelector('button');\n  btn.style.opacity = '.5';\n  btn.disabled = true;\n  setTimeout(() => {\n    btn.style.display = 'none';\n    document.getElementById('form-ok').style.display = 'block';\n  }, 600);\n});\n</script>\n",
