               </div>\n            </div>\n        </div>\n    </div>\n  </section>\n\n  \n  <section id=\"carousel-cards\" class=\"py-32 bg-black/50 border-y border-white/5\" data-kid=\"190\">\n    <div class=\"max-w-7xl mx-auto px-8 mb-20 flex flex-col md:flex-row justify-between items-end gap-6\" data-kid=\"191\">\n        <div data-kid=\"192\">\n            <span class=\"font-mono text-[var(--cyan)] text-xs tracking-[0.3em] uppercase block mb-2\" data-kid=\"193\">// PROJECT_ARCHIVE</span>\n            <h2 class=\"text-4xl md:text-6xl font-bold tracking-tighter uppercase\" data-kid=\"194\">Deployed Assets</h2>\n        </div>\n        <div class=\"flex gap-4\" data-kid=\"195\">\n            <button class=\"nav-prev w-14 h-14 rounded-full border border-white/10 flex items-center justify-center hover:bg-[var(--cyan)] hover:text-black transition-all cursor-pointer\" data-kid=\"196\">\n                <i class=\"ti ti-chevron-left text-2xl\" data-kid=\"197\"></i>\n            </button>\n            <button class=\"nav-next w-14 h-14 rounded-full border border-white/10 flex items-center justify-center hover:bg-[var(--cyan)] hover:text-black transition-all cursor-pointer\" data-kid=\"198\">\n                <i class=\"ti ti-chevron-right text-2xl\" data-kid=\"199\"></i>\n            </button>\n        </div>\n    </div>\n\n    \n    <div class=\"flex gap-8 px-8 overflow-x-auto no-scrollbar snap-x pb-12 cursor-grab active:cursor-grabbing\" data-kid=\"200\">\n        \n        <div class=\"min-w-[320px] md:min-w-[700px] snap-center cursor-glow-container\" data-kid=\"201\">\n            <div class=\"cursor-glow\" data-kid=\"202\"></div>\n            \n            <div class=\"neon-card rounded-3xl aspect-video overflow-hidden relative group\" data-kid=\"203\">\n                <img src=\"https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&w=1200&q=80\" alt=\"Project 1\" class=\"w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"204\">\n                <div class=\"absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent\" data-kid=\"205\"></div>\n                <div class=\"absolute bottom-8 left-8\" data-kid=\"206\">\n                    <div class=\"font-mono text-[10px] text-[var(--cyan)] mb-2 uppercase\" data-kid=\"207\">DEPLOYED: 2024.03.12</div>\n                    <h3 class=\"text-3xl font-bold uppercase tracking-widest\" data-kid=\"208\">CYBER_DYNE CMS</h3>\n                </div>\n            </div>\n            <div class=\"mt-8 flex justify-between items-center px-4\" data-kid=\"209\">\n                <p class=\"text-white/40 font-mono text-sm max-w-md\" data-kid=\"210\">Multi-tenant architecture for industrial logistics network with custom API routing.</p>\n                <a href=\"#\" class=\"text-[var(--cyan)] font-bold text-sm tracking-[0.2em] border-b border-[var(--cyan)] pb-1 hover:text-white hover:border-white transition-all\" data-kid=\"211\">_EXPLORE</a>\n            </div>\n        </div>\n\n        \n        <div class=\"min-w-[320px] md:min-w-[700px] snap-center cursor-glow-container\" data-kid=\"212\">\n            <div class=\"cursor-glow\" data-kid=\"213\"></div>\n            <div class=\"neon-card rounded-3xl aspect-video overflow-hidden relative group\" data-kid=\"214\">\n                <img src=\"https://images.unsplash.com/photo-1547082299-de196ea013d6?auto=format&w=1200&q=80\" alt=\"Project 2\" class=\"w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"215\">\n                <div class=\"absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent\" data-kid=\"216\"></div>\n                <div class=\"absolute bottom-8 left-8\" data-kid=\"217\">\n                    <div class=\"font-mono text-[10px] text-[var(--cyan)] mb-2 uppercase\" data-kid=\"218\">DEPLOYED: 2024.01.05</div>\n                    <h3 class=\"text-3xl font-bold uppercase tracking-widest\" data-kid=\"219\">NEO_TECH HUB</h3>\n                </div>\n            </div>\n            <div class=\"mt-8 flex justify-between items-center px-4\" data-kid=\"220\">\n                <p class=\"text-white/40 font-mono text-sm max-w-md\" data-kid=\"221\">Decoupled WordPress with Next.js frontend for a major high-tech incubator.</p>\n                <a href=\"#\" class=\"text-[var(--cyan)] font-bold text-sm tracking-[0.2em] border-b border-[var(--cyan)] pb-1 hover:text-white hover:border-white transition-all\" data-kid=\"222\">_EXPLORE</a>\n            </div>\n        </div>\n\n        \n        <div class=\"min-w-[320px] md:min-w-[700px] snap-center cursor-glow-container\" data-kid=\"223\">\n            <div class=\"cursor-glow\" data-kid=\"224\"></div>\n            <div class=\"neon-card rounded-3xl aspect-video overflow-hidden relative group\" data-kid=\"225\">\n                <img src=\"https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&w=1200&q=80\" alt=\"Project 3\" class=\"w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"226\">\n                <div class=\"absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent\" data-kid=\"227\"></div>\n                <div class=\"absolute bottom-8 left-8\" data-kid=\"228\">\n                    <div class=\"font-mono text-[10px] text-[var(--cyan)] mb-2 uppercase\" data-kid=\"229\">DEPLOYED: 2023.11.20</div>\n                    <h3 class=\"text-3xl font-bold uppercase tracking-widest\" data-kid=\"230\">ORBITAL E-COM</h3>\n                </div>\n            </div>\n            <div class=\"mt-8 flex justify-between items-center px-4\" data-kid=\"231\">\n                <p class=\"text-white/40 font-mono text-sm max-w-md\" data-kid=\"232\">Global marketplace with real-time inventory synchronization across 12 nodes.</p>\n                <a href=\"#\" class=\"text-[var(--cyan)] font-bold text-sm tracking-[0.2em] border-b border-[var(--cyan)] pb-1 hover:text-white hover:border-white transition-all\" data-kid=\"233\">_EXPLORE</a>\n            </div>\n        </div>\n    </div>\n  </section>\n\n  \n  <footer id=\"split-nav\" class=\"bg-black py-32 relative overflow-hidden\" data-kid=\"234\">\n    <div class=\"scan-line\" id=\"footer-scan\" data-kid=\"235\"></div>\n    \n    <div class=\"absolute top-1/2 left-0 -translate-y-1/2 -translate-x-1/3 opacity-5 pointer-events-none\" data-kid=\"236\">\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/alien-skull.svg\" style=\"color: #00FFFF;\" class=\"w-[800px] h-[800px]\" data-kid=\"237\">\n    </div>\n\n    <div class=\"max-w-7xl mx-auto px-8 relative z-10\" data-kid=\"238\">\n        \n        <div class=\"flex gap-4 mb-16 opacity-20 font-mono text-[10px]\" data-kid=\"239\">\n            <span data-kid=\"240\">NODE: NOVA_ROOT</span>\n            <span data-kid=\"241\">SEC: ENCRYPT_01</span>\n            <span data-kid=\"242\">VER: 2.4.0</span>\n        </div>\n        <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-20 items-center\" data-kid=\"243\">\n            <div data-kid=\"244\">\n                <h2 class=\"text-6xl md:text-8xl font-bold tracking-tighter uppercase mb-8\" data-kid=\"245\">Ready to<br data-kid=\"246\"><span class=\"text-[var(--cyan)]\" data-kid=\"247\">Execute?</span></h2>\n                <div class=\"flex gap-8 mb-12\" data-kid=\"248\">\n                    <div class=\"flex flex-col\" data-kid=\"249\">\n                        <span class=\"font-mono text-[10px] text-white/30 uppercase mb-2\" data-kid=\"250\">Primary_Link</span>\n                        <a href=\"mailto:contact@novasystems.io\" class=\"text-xl hover:text-[var(--cyan)] transition-colors underline decoration-[var(--cyan)]/30\" data-kid=\"251\">contact@novasystems.io</a>\n                    </div>\n                    <div class=\"flex flex-col\" data-kid=\"252\">\n                        <span class=\"font-mono text-[10px] text-white/30 uppercase mb-2\" data-kid=\"253\">Comms_Frequency</span>\n                        <a href=\"#\" class=\"text-xl hover:text-[var(--cyan)] transition-colors underline decoration-[var(--cyan)]/30\" data-kid=\"254\">+1 (800) NOVA-SYS</a>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"flex flex-col items-start lg:items-end\" data-kid=\"255\">\n                <button class=\"group relative px-12 py-6 bg-[var(--magenta)] text-white font-bold uppercase tracking-[0.4em] mb-12 w-full lg:w-auto overflow-hidden\" data-kid=\"256\">\n                    <span class=\"relative z-10\" data-kid=\"257\">Iniciar Secuencia</span>\n                    <div class=\"absolute inset-0 bg-white translate-x-full group-hover:translate-x-0 transition-transform duration-300\" data-kid=\"258\"></div>\n                    <div class=\"absolute inset-0 border border-white opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"259\"></div>\n                </button>\n                <div class=\"grid grid-cols-2 md:grid-cols-4 gap-12 text-xs font-mono tracking-widest text-white/40 mb-12\" data-kid=\"260\">\n                    <a href=\"#\" class=\"hover:text-[var(--cyan)] transition-colors\" data-kid=\"261\">GITHUB</a>\n                    <a href=\"#\" class=\"hover:text-[var(--cyan)] transition-colors\" data-kid=\"262\">LINKEDIN</a>\n                    <a href=\"#\" class=\"hover:text-[var(--cyan)] transition-colors\" data-kid=\"263\">TWITTER</a>\n                    <a href=\"#\" class=\"hover:text-[var(--cyan)] transition-colors\" data-kid=\"264\">BEHANCE</a>\n                </div>\n                <div class=\"text-[10px] font-mono text-white/20 uppercase tracking-[0.2em] text-right\" data-kid=\"265\">\n                    © 2024 NOVA SYSTEMS // NEURAL_NET_V2 // ALL RIGHTS RESERVED\n                </div>\n            </div>\n        </div>\n    </div>\n  </footer>\n\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"266\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"267\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/TextPlugin.min.js\" data-kid=\"268\"></script>\n<script type=\"module\" data-kid=\"269\">\n  import { animate } from 'https://esm.sh/animejs@4';\n  import Lenis from \"https://esm.sh/lenis@1\"\n\n  // Plugins\n  gsap.registerPlugin(ScrollTrigger, TextPlugin);\n\n  // Smooth Scroll\n  const lenis = new Lenis();\n  function raf(time) {\n    lenis.raf(time);\n    requestAnimationFrame(raf);\n  }\n  requestAnimationFrame(raf);\n\n  // Hero Terminal Typing Animation\n  const typingTimeline = gsap.timeline();\n  typingTimeline.to(\"#hero-typing-target\", {\n    duration: 2.5,\n    text: \"nova_systems --deploy-future\",\n    ease: \"none\"\n  }).to(\"#hero-content\", {\n    opacity: 1,\n    duration: 1,\n    y: 0,\n    ease: \"power2.out\"\n  });\n\n  // Scanline Effects using Anime.js\n  animate(\"#center-scan\", {\n    top: [\"0%\", \"100%\"],\n    opacity: [0, 0.5, 0],\n    duration: 4000,\n    loop: true,\n    easing: \"linear\"\n  });\n\n  animate(\"#footer-scan\", {\n    top: [\"0%\", \"100%\"],\n    opacity: [0, 0.5, 0],\n    duration: 5000,\n    loop: true,\n    easing: \"linear\"\n  });\n\n  // Pulse CTA using Anime.js\n  animate(\"#main-cta-pulse\", {\n    scale: [1, 1.05],\n    duration: 1500,\n    direction: \"alternate\",\n    loop: true,\n    easing: \"easeInOutQuad\"\n  });\n\n  // Service Dashboard Interaction\n  const serviceTriggers = document.querySelectorAll('.service-trigger');\n  const holoIcon = document.getElementById('holo-icon');\n  const holoTitle = document.getElementById('holo-title');\n  const holoDesc = document.getElementById('holo-desc');\n\n  const servicesData = {\n    landing: {\n      icon: 'ti-augmented-reality-2',\n      title: 'Landing Protocol',\n      desc: 'Simulating user-centric interface flow with 99.9% conversion probability.'\n    },\n    ecommerce: {\n      icon: 'ti-shopping-cart-bolt',\n      title: 'Commerce Core',\n      desc: 'High-throughput transactional engine with decentralized inventory management.'\n    },\n    informative: {\n      icon: 'ti-database-cog',\n      title: 'Knowledge Hub',\n      desc: 'Content-dense architecture optimized for semantic search and high-speed retrieval.'\n    },\n    custom: {\n      icon: 'ti-cpu',\n      title: 'Custom Logic',\n      desc: 'Unique algorithmic solutions for specialized operational requirements.'\n    }\n  };\n\n  serviceTriggers.forEach(trigger => {\n    trigger.addEventListener('click', () => {\n      serviceTriggers.forEach(t => t.classList.remove('active', 'bg-[var(--secondary)]', 'border-[var(--cyan)]'));\n      serviceTriggers.forEach(t => t.classList.add('bg-white/5', 'border-transparent'));\n      \n      trigger.classList.remove('bg-white/5', 'border-transparent');\n      trigger.classList.add('active', 'bg-[var(--secondary)]', 'border-[var(--cyan)]');\n\n      const target = trigger.getAttribute('data-target');\n      const data = servicesData[target];\n\n      gsap.timeline()\n        .to('.holographic', { opacity: 0.3, duration: 0.15, filter: 'blur(10px)', skewX: 5 })\n        .set(holoIcon, { innerHTML: `<i class=\"ti ${data.icon} text-8xl text-[var(--cyan)] glow-cyan\"></i>` })\n        .set(holoTitle, { innerText: data.title })\n        .set(holoDesc, { innerText: data.desc })\n        .to('.holographic', { opacity: 1, duration: 0.3, filter: 'blur(0px)', skewX: 0, ease: \"back.out(1.7)\" });\n    });\n  });\n\n  // Cursor Glow Interaction\n  document.querySelectorAll('.cursor-glow-container').forEach(container => {\n    const glow = container.querySelector('.cursor-glow');\n    container.addEventListener('mousemove', (e) => {\n        const rect = container.getBoundingClientRect();\n        const x = e.clientX - rect.left;\n        const y = e.clientY - rect.top;\n        gsap.to(glow, { x: x, y: y, duration: 0.2 });\n    });\n  });\n\n  // Reveal Animations\n  gsap.from(\".glass\", {\n    scrollTrigger: {\n        trigger: \"#glass-grid\",\n        start: \"top 85%\",\n    },\n    y: 100,\n    opacity: 0,\n    duration: 1.5,\n    stagger: 0.1,\n    ease: \"power4.out\"\n  });\n\n  // Handle hover transitions via GSAP to avoid conflict with CSS transitions\n  document.querySelectorAll('.glass').forEach(card => {\n    card.addEventListener('mouseenter', () => {\n        const targetColor = card.getAttribute('data-color') === 'cyan' ? 'rgba(0,255,255,1)' : 'rgba(255,0,255,1)';\n        gsap.to(card, { \n            scale: 1.02, \n            y: -10, \n            borderColor: targetColor,\n            duration: 0.4, \n            ease: \"power2.out\" \n        });\n    });\n    card.addEventListener('mouseleave', () => {\n        gsap.to(card, { \n            scale: 1, \n            y: 0, \n            borderColor: 'rgba(255,255,255,0.05)',\n            duration: 0.4, \n            ease: \"power2.out\" \n        });\n    });\n  });\n\n</script>\n",
