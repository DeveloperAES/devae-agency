      "html": "\n<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@300;400;500;600;700&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n:root {\n  --onyx: #111111;\n  --jet: #2A3439;\n  --gold: #D4AF37;\n}\n\nbody {\n  background-color: var(--onyx);\n  color: white;\n  font-family: 'Space Grotesk', sans-serif;\n  margin: 0;\n  overflow-x: clip;\n}\n\n.font-anton { font-family: 'Anton', sans-serif; }\n\n.brutalist-border { border: 3px solid var(--jet); }\n\n.neon-glow-gold {\n  border: 1.5px solid var(--gold);\n  box-shadow: 0 0 12px rgba(212,175,55,0.2), 0 0 36px rgba(212,175,55,0.06);\n}\n\n.corner-bracket { position: relative; }\n.corner-bracket::before, .corner-bracket::after,\n.corner-bracket span::before, .corner-bracket span::after {\n  content: '';\n  position: absolute;\n  width: 24px;\n  height: 24px;\n  border-color: var(--gold);\n  pointer-events: none;\n}\n.corner-bracket::before { top: 0; left: 0; border-top: 2px solid; border-left: 2px solid; }\n.corner-bracket::after  { top: 0; right: 0; border-top: 2px solid; border-right: 2px solid; }\n.corner-bracket span::before { bottom: 0; left: 0; border-bottom: 2px solid; border-left: 2px solid; }\n.corner-bracket span::after  { bottom: 0; right: 0; border-bottom: 2px solid; border-right: 2px solid; }\n\n.crosshatch { position: relative; }\n.crosshatch::after {\n  content: '';\n  position: absolute;\n  inset: 0;\n  opacity: 0.06;\n  background-image:\n    repeating-linear-gradient(45deg, #000, #000 1px, transparent 1px, transparent 6px),\n    repeating-linear-gradient(-45deg, #000, #000 1px, transparent 1px, transparent 6px);\n  pointer-events: none;\n}\n\n.rotate-wireframe { animation: rotate3D 20s linear infinite; }\n@keyframes rotate3D {\n  from { transform: rotateY(0deg) rotateX(0deg); }\n  to   { transform: rotateY(360deg) rotateX(360deg); }\n}\n\n.ledger-row { border-bottom: 1px solid rgba(255,255,255,0.08); }\n\n.portfolio-reveal { clip-path: inset(0 100% 0 0); }\n\n.watermark-text {\n  font-size: clamp(8rem, 20vw, 24rem);\n  line-height: 0.8;\n  letter-spacing: -0.05em;\n  color: rgba(255,255,255,0.02);\n  user-select: none;\n}\n\n/* ---- Contact Form ---- */\n.contact-input {\n  background: transparent;\n  border: none;\n  border-bottom: 2px solid rgba(255,255,255,0.12);\n  color: white;\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 1rem;\n  padding: 16px 0;\n  width: 100%;\n  outline: none;\n  letter-spacing: 0.04em;\n}\n.contact-input::placeholder { color: rgba(255,255,255,0.25); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; }\n.contact-input:focus { border-bottom-color: var(--gold); }\n\n.contact-select {\n  -webkit-appearance: none;\n  -moz-appearance: none;\n  appearance: none;\n  background: transparent;\n  border: none;\n  border-bottom: 2px solid rgba(255,255,255,0.12);\n  color: rgba(255,255,255,0.4);\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 0.875rem;\n  padding: 16px 0;\n  width: 100%;\n  outline: none;\n  letter-spacing: 0.1em;\n  text-transform: uppercase;\n  cursor: pointer;\n}\n.contact-select:focus { border-bottom-color: var(--gold); color: white; }\n.contact-select option { background: #1a1a1a; color: white; }\n\n/* Animated typing cursor */\n@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }\n.cursor { display: inline-block; width: 3px; height: 1em; background: var(--gold); vertical-align: middle; margin-left: 4px; animation: blink 1s step-end infinite; }\n\n/* AE Logo pulse */\n@keyframes logoGlow {\n  0%,100% { filter: drop-shadow(0 0 4px rgba(212,175,55,0.3)); }\n  50%      { filter: drop-shadow(0 0 12px rgba(212,175,55,0.7)); }\n}\n.ae-logo-svg { animation: logoGlow 3s ease-in-out infinite; }\n</style>\n\n<div id=\"smooth-wrapper\" data-kid=\"1\">\n  <div id=\"smooth-content\" data-kid=\"2\">\n\n    \n    <nav class=\"fixed top-0 left-0 w-full z-50 p-6 flex justify-between items-center\" style=\"background: linear-gradient(to bottom, rgba(17,17,17,0.95) 0%, transparent 100%); backdrop-filter: blur(8px);\" data-kid=\"3\">\n      \n      <div class=\"flex items-center gap-3\" data-kid=\"4\">\n        <svg class=\"ae-logo-svg\" width=\"48\" height=\"32\" viewBox=\"0 0 48 32\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"5\">\n          \n          <path d=\"M2 30L12 2L22 30\" stroke=\"#D4AF37\" stroke-width=\"2.5\" stroke-linecap=\"square\" fill=\"none\" data-kid=\"6\"></path>\n          <path d=\"M5 20L19 20\" stroke=\"#D4AF37\" stroke-width=\"2.5\" stroke-linecap=\"square\" data-kid=\"7\"></path>\n          \n          <path d=\"M28 2L28 30\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"square\" data-kid=\"8\"></path>\n          <path d=\"M28 2L44 2\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"square\" data-kid=\"9\"></path>\n          <path d=\"M28 16L41 16\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"square\" data-kid=\"10\"></path>\n          <path d=\"M28 30L44 30\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"square\" data-kid=\"11\"></path>\n          \n          <rect x=\"45\" y=\"28\" width=\"3\" height=\"3\" fill=\"#D4AF37\" data-kid=\"12\"></rect>\n        </svg>\n        <div data-kid=\"13\">\n          <div class=\"font-anton text-lg uppercase tracking-tighter leading-none\" data-kid=\"14\">Anderson <span style=\"color:var(--gold)\" data-kid=\"15\">Espinoza</span></div>\n          <div class=\"text-[9px] uppercase tracking-[0.35em] opacity-40 font-bold\" data-kid=\"16\">DevAE · Dev Agency</div>\n        </div>\n      </div>\n      <div class=\"flex gap-8 items-center text-xs uppercase tracking-widest font-bold\" data-kid=\"17\">\n        <a href=\"#services\" class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"18\">Servicios</a>\n        <a href=\"#tech\" class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"19\">Tecnología</a>\n        <a href=\"#portfolio\" class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"20\">Portfolio</a>\n        <a href=\"#contact\" class=\"px-6 py-2 border border-white/20 hover:border-[var(--gold)] hover:text-[var(--gold)] transition-colors\" data-kid=\"21\">Contacto</a>\n      </div>\n    </nav>\n\n    \n    <section id=\"dashboard-bento\" class=\"min-h-screen pt-24 pb-12 px-6 flex flex-col justify-center\" data-kid=\"22\">\n      <div class=\"grid grid-cols-12 grid-rows-6 gap-4 h-[85vh]\" data-kid=\"23\">\n\n        \n        <div class=\"reveal-hero col-span-8 row-span-4 bg-[var(--jet)] p-12 brutalist-border flex flex-col justify-between relative overflow-hidden group\" data-kid=\"24\">\n          <div class=\"absolute -top-24 -right-24 w-64 h-64 bg-[var(--gold)]/5 blur-3xl rounded-full\" data-kid=\"25\"></div>\n          <div class=\"relative z-10 flex justify-between items-start\" data-kid=\"26\">\n            <h1 class=\"font-anton text-[clamp(4rem,10vw,9rem)] uppercase leading-[0.85] tracking-tighter\" id=\"hero-headline\" data-kid=\"27\">\n              Construimos<br data-kid=\"28\">la Web<span class=\"cursor\" data-kid=\"29\"></span>\n            </h1>\n            <i class=\"ti ti-hammer text-7xl text-[var(--gold)] drop-shadow-[0_0_10px_rgba(212,175,55,0.3)]\" data-kid=\"30\"></i>\n          </div>\n          <div class=\"relative z-10 flex justify-between items-end\" data-kid=\"31\">\n            <p class=\"text-xl max-w-lg opacity-60 leading-relaxed font-light\" data-kid=\"32\">\n              Desarrollamos sistemas digitales robustos con precisión arquitectónica y escalabilidad de clase mundial.\n            </p>\n            <div class=\"text-xs uppercase tracking-widest opacity-40 font-bold border-t border-white/10 pt-4\" data-kid=\"33\">\n              [ v4.2.0 ] / Architectural Core\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"reveal-hero col-span-4 row-span-2 bg-[var(--jet)] brutalist-border flex items-center justify-center overflow-hidden relative group\" data-kid=\"34\">\n          <div class=\"absolute inset-0 bg-gradient-to-br from-[var(--gold)]/5 to-transparent\" data-kid=\"35\"></div>\n          <div class=\"rotate-wireframe opacity-30 group-hover:opacity-60\" style=\"transition: opacity .7s\" data-kid=\"36\">\n            <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/cube.svg\" class=\"w-40 h-40 filter invert\" alt=\"3D Cube\" decoding=\"async\" loading=\"lazy\" data-kid=\"37\">\n          </div>\n        </div>\n\n        \n        <div class=\"reveal-hero col-span-4 row-span-2 bg-[var(--jet)] brutalist-border p-8 flex flex-col justify-center items-center relative overflow-hidden\" data-kid=\"38\">\n          <div class=\"absolute top-0 left-0 w-full h-1 bg-[var(--gold)]/20\" data-kid=\"39\"></div>\n          <div class=\"flex items-baseline gap-2\" data-kid=\"40\">\n            <span class=\"text-6xl font-anton text-[var(--gold)] leading-none\" data-kid=\"41\">&lt;</span>\n            <span class=\"text-7xl font-anton text-[var(--gold)] leading-none\" id=\"latency-counter\" data-kid=\"42\">200</span>\n            <span class=\"text-3xl font-anton text-[var(--gold)]/40 uppercase\" data-kid=\"43\">ms</span>\n          </div>\n          <span class=\"text-xs uppercase tracking-widest mt-4 opacity-50 font-bold\" data-kid=\"44\">Tiempo de Respuesta</span>\n        </div>\n\n        \n        <a href=\"#contact\" class=\"reveal-hero col-span-4 row-span-2 bg-[var(--gold)] text-black p-10 flex flex-col justify-between group\" style=\"cursor:pointer\" data-kid=\"45\">\n          <div class=\"flex justify-between items-start\" data-kid=\"46\">\n            <h3 class=\"font-anton text-4xl uppercase leading-none\" data-kid=\"47\">Inicia tu<br data-kid=\"48\">proyecto</h3>\n            <i class=\"ti ti-arrow-up-right text-5xl\" data-kid=\"49\"></i>\n          </div>\n          <div class=\"flex items-center gap-4 text-xs font-bold uppercase tracking-widest border-t border-black/10 pt-6\" data-kid=\"50\">\n            <span class=\"w-2 h-2 bg-black rounded-full animate-ping\" data-kid=\"51\"></span>\n            Disponibilidad inmediata\n          </div>\n        </a>\n\n        \n        <div class=\"reveal-hero col-span-8 row-span-2 brutalist-border flex items-center px-12 gap-16 relative bg-[var(--jet)]\" data-kid=\"52\">\n          <div class=\"flex flex-col gap-1\" data-kid=\"53\">\n            <span class=\"text-xs uppercase text-[var(--gold)]/60 font-bold tracking-[0.2em]\" data-kid=\"54\">01 / Frontend</span>\n            <span class=\"font-anton text-xl uppercase\" data-kid=\"55\">React / Next.js / Vue</span>\n          </div>\n          <div class=\"w-px h-12 bg-white/10\" data-kid=\"56\"></div>\n          <div class=\"flex flex-col gap-1\" data-kid=\"57\">\n            <span class=\"text-xs uppercase text-[var(--gold)]/60 font-bold tracking-[0.2em]\" data-kid=\"58\">02 / Backend</span>\n            <span class=\"font-anton text-xl uppercase\" data-kid=\"59\">Node.js / WordPress / PHP</span>\n          </div>\n          <div class=\"w-px h-12 bg-white/10\" data-kid=\"60\"></div>\n          <div class=\"flex flex-col gap-1\" data-kid=\"61\">\n            <span class=\"text-xs uppercase text-[var(--gold)]/60 font-bold tracking-[0.2em]\" data-kid=\"62\">03 / Infrastructure</span>\n            <span class=\"font-anton text-xl uppercase\" data-kid=\"63\">AWS / Vercel / Docker</span>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"modular-tiles\" class=\"py-32 px-6 bg-[var(--onyx)]\" data-kid=\"64\">\n      <div class=\"max-w-7xl mx-auto\" data-kid=\"65\">\n        <div class=\"grid grid-cols-12 gap-8 items-start mb-24\" data-kid=\"66\">\n          <div class=\"col-span-12 md:col-span-8 reveal-service\" data-kid=\"67\">\n            <span class=\"text-[var(--gold)] text-sm font-bold uppercase tracking-[0.4em] block mb-4\" data-kid=\"68\">// Arquitectura Modular</span>\n            <h2 class=\"font-anton text-7xl md:text-8xl uppercase leading-[0.9]\" data-kid=\"69\">Bloques Digitales de Alta Performance</h2>\n          </div>\n          <div class=\"col-span-12 md:col-span-4 reveal-service flex flex-col gap-6 pt-12\" data-kid=\"70\">\n            <p class=\"text-lg opacity-50 leading-relaxed\" data-kid=\"71\">\n              No construimos sitios web; forjamos infraestructuras de negocio que combinan la rigidez arquitectónica con la flexibilidad del software moderno.\n            </p>\n            <div class=\"h-px w-24 bg-[var(--gold)]\" data-kid=\"72\"></div>\n          </div>\n        </div>\n        <div class=\"grid grid-cols-12 gap-1 border-t border-white/10 pt-1\" data-kid=\"73\">\n          <div class=\"col-span-12 md:col-span-3 reveal-service bg-[var(--jet)] p-12 flex flex-col min-h-[400px] justify-between group\" data-kid=\"74\">\n            <div class=\"flex justify-between items-start\" data-kid=\"75\">\n              <i class=\"ti ti-monitor-smartphone text-4xl text-[var(--gold)]\" data-kid=\"76\"></i>\n              <span class=\"text-xs font-bold opacity-30\" data-kid=\"77\">01</span>\n            </div>\n            <div data-kid=\"78\">\n              <h3 class=\"font-anton text-3xl uppercase mb-4 group-hover:text-[var(--gold)] transition-colors\" data-kid=\"79\">Landing<br data-kid=\"80\">Pages</h3>\n              <p class=\"text-sm opacity-50 uppercase tracking-widest leading-loose\" data-kid=\"81\">Estructuras de conversión optimizadas para tráfico de alta densidad.</p>\n            </div>\n          </div>\n          <div class=\"col-span-12 md:col-span-3 reveal-service bg-[var(--jet)] p-12 flex flex-col min-h-[400px] justify-between group\" data-kid=\"82\">\n            <div class=\"flex justify-between items-start\" data-kid=\"83\">\n              <i class=\"ti ti-book-open text-4xl text-[var(--gold)]\" data-kid=\"84\"></i>\n              <span class=\"text-xs font-bold opacity-30\" data-kid=\"85\">02</span>\n            </div>\n            <div data-kid=\"86\">\n              <h3 class=\"font-anton text-3xl uppercase mb-4 group-hover:text-[var(--gold)] transition-colors\" data-kid=\"87\">Portales<br data-kid=\"88\">Marca</h3>\n              <p class=\"text-sm opacity-50 uppercase tracking-widest leading-loose\" data-kid=\"89\">Sitios informativos con autoridad visual y narrativa técnica impecable.</p>\n            </div>\n          </div>\n          <div class=\"col-span-12 md:col-span-6 reveal-service bg-[var(--jet)] p-12 flex flex-col min-h-[400px] justify-between group relative overflow-hidden\" data-kid=\"90\">\n            <div class=\"absolute -right-12 -bottom-12 opacity-[0.03] group-hover:opacity-[0.08] transition-opacity\" data-kid=\"91\">\n              <i class=\"ti ti-shopping-cart text-[16rem]\" data-kid=\"92\"></i>\n            </div>\n            <div class=\"flex justify-between items-start\" data-kid=\"93\">\n              <i class=\"ti ti-shopping-cart text-4xl text-[var(--gold)]\" data-kid=\"94\"></i>\n              <span class=\"text-xs font-bold opacity-30\" data-kid=\"95\">03</span>\n            </div>\n            <div class=\"max-w-md\" data-kid=\"96\">\n              <h3 class=\"font-anton text-5xl uppercase mb-6 group-hover:text-[var(--gold)] transition-colors\" data-kid=\"97\">E-commerce<br data-kid=\"98\">Enterprise</h3>\n              <p class=\"text-sm opacity-60 leading-relaxed mb-6\" data-kid=\"99\">Infraestructuras transaccionales masivas, integraciones ERP/CRM y checkout personalizado sin fricciones.</p>\n              <div class=\"flex gap-4\" data-kid=\"100\">\n                <span class=\"text-xs px-3 py-1 border border-[var(--gold)]/20 text-[var(--gold)]/60 font-bold uppercase tracking-widest\" data-kid=\"101\">WooCommerce</span>\n                <span class=\"text-xs px-3 py-1 border border-[var(--gold)]/20 text-[var(--gold)]/60 font-bold uppercase tracking-widest\" data-kid=\"102\">Shopify Plus</span>\n              </div>\n            </div>\n          </div>\n          <div class=\"col-span-12 reveal-service bg-[var(--jet)] p-16 flex flex-col md:flex-row items-center justify-between group mt-1 corner-bracket\" data-kid=\"103\">\n            <span data-kid=\"104\"></span>\n            <div class=\"flex flex-col gap-6 md:w-1/2\" data-kid=\"105\">\n              <div class=\"flex items-center gap-6\" data-kid=\"106\">\n                <i class=\"ti ti-database text-5xl text-[var(--gold)]\" data-kid=\"107\"></i>\n                <span class=\"text-xs font-bold opacity-30 uppercase tracking-[0.5em]\" data-kid=\"108\">Systems Engineering</span>\n              </div>\n              <h3 class=\"font-anton text-5xl md:text-6xl uppercase leading-none group-hover:text-[var(--gold)] transition-colors\" data-kid=\"109\">Arquitectura de Sistemas & APIs</h3>\n            </div>\n            <div class=\"md:w-1/3 flex flex-col gap-6 pt-8 md:pt-0\" data-kid=\"110\">\n              <p class=\"text-sm opacity-60 leading-relaxed uppercase tracking-widest\" data-kid=\"111\">Desarrollo de backends robustos, dashboards de gestión críticos y ecosistemas de microservicios escalables.</p>\n              <div class=\"flex gap-4 items-center text-[var(--gold)]\" data-kid=\"112\">\n                <span class=\"font-anton text-xl uppercase\" data-kid=\"113\">Ver Documentación Técnica</span>\n                <i class=\"ti ti-arrow-right text-2xl\" data-kid=\"114\"></i>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"capability-ledger\" class=\"py-40 bg-[var(--onyx)] relative overflow-hidden\" data-kid=\"115\">\n      <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 watermark-text select-none pointer-events-none font-anton opacity-[0.04]\" data-kid=\"116\">WORDPRESS</div>\n      <div class=\"max-w-6xl mx-auto px-6 relative z-10\" data-kid=\"117\">\n        <div class=\"mb-32 flex flex-col md:flex-row items-baseline gap-8\" data-kid=\"118\">\n          <span class=\"text-[var(--gold)] text-sm font-bold uppercase tracking-[0.5em] block mb-4 md:rotate-90 md:origin-left md:whitespace-nowrap\" data-kid=\"119\">// Tech Stack</span>\n          <h2 class=\"font-anton text-7xl md:text-9xl uppercase leading-[0.8]\" data-kid=\"120\">WP<br data-kid=\"121\"><span class=\"text-[var(--gold)]\" data-kid=\"122\">Mastery</span></h2>\n        </div>\n        <div class=\"flex flex-col border-t border-white/10\" id=\"ledger-list\" data-kid=\"123\">\n          <div class=\"reveal-ledger ledger-row py-12 flex flex-col md:flex-row justify-between items-start md:items-end group cursor-default\" data-kid=\"124\">\n            <div class=\"mb-4 md:mb-0\" data-kid=\"125\">\n              <span class=\"text-[var(--gold)] text-xs font-bold uppercase tracking-widest block mb-4\" data-kid=\"126\">01 / Architectural Design</span>\n              <h3 class=\"text-5xl font-anton uppercase group-hover:text-[var(--gold)] transition-colors\" data-kid=\"127\">Engineered Theme Core</h3>\n              <p class=\"text-sm opacity-50 mt-2 max-w-lg\" data-kid=\"128\">Sistemas de diseño atómico implementados sin Page Builders. Rendimiento nativo extremo.</p>\n            </div>\n            <div class=\"text-right\" data-kid=\"129\">\n              <span class=\"text-6xl font-anton leading-none\" data-kid=\"130\">99/100</span>\n              <p class=\"text-xs uppercase font-bold tracking-widest opacity-40 mt-3\" data-kid=\"131\">Lighthouse Performance</p>\n            </div>\n          </div>\n          <div class=\"reveal-ledger ledger-row py-12 flex flex-col md:flex-row justify-between items-start md:items-end group cursor-default\" data-kid=\"132\">\n            <div class=\"mb-4 md:mb-0\" data-kid=\"133\">\n              <span class=\"text-[var(--gold)] text-xs font-bold uppercase tracking-widest block mb-4\" data-kid=\"134\">02 / Scaling Operations</span>\n              <h3 class=\"text-5xl font-anton uppercase group-hover:text-[var(--gold)] transition-colors\" data-kid=\"135\">WooCommerce Enterprise</h3>\n              <p class=\"text-sm opacity-50 mt-2 max-w-lg\" data-kid=\"136\">Orquestación de catálogos masivos y sincronización en tiempo real con sistemas externos.</p>\n            </div>\n            <div class=\"text-right\" data-kid=\"137\">\n              <span class=\"text-6xl font-anton leading-none\" data-kid=\"138\">+500k</span>\n              <p class=\"text-xs uppercase font-bold tracking-widest opacity-40 mt-3\" data-kid=\"139\">Request Capacity / Hour</p>\n            </div>\n          </div>\n          <div class=\"reveal-ledger ledger-row py-12 flex flex-col md:flex-row justify-between items-start md:items-end group cursor-default\" data-kid=\"140\">\n            <div class=\"mb-4 md:mb-0\" data-kid=\"141\">\n              <span class=\"text-[var(--gold)] text-xs font-bold uppercase tracking-widest block mb-4\" data-kid=\"142\">03 / Decoupled Future</span>\n              <h3 class=\"text-5xl font-anton uppercase group-hover:text-[var(--gold)] transition-colors\" data-kid=\"143\">Headless / Jamstack WP</h3>\n              <p class=\"text-sm opacity-50 mt-2 max-w-lg\" data-kid=\"144\">WordPress como backend de datos con frontends en Next.js via GraphQL para velocidad infinita.</p>\n            </div>\n            <div class=\"text-right\" data-kid=\"145\">\n              <span class=\"text-6xl font-anton leading-none\" data-kid=\"146\">&lt;120ms</span>\n              <p class=\"text-xs uppercase font-bold tracking-widest opacity-40 mt-3\" data-kid=\"147\">Edge Node Response</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"filterable-grid\" class=\"py-40 bg-[var(--onyx)] px-6\" data-kid=\"148\">\n      <div class=\"max-w-7xl mx-auto\" data-kid=\"149\">\n        <div class=\"flex flex-col md:flex-row justify-between items-end mb-24 gap-12\" data-kid=\"150\">\