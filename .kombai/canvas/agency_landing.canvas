kground:var(--bg);padding:48px;display:flex;flex-direction:column;gap:24px;cursor:default;\" data-reveal data-kid=\"73\">\n        <div style=\"display:flex;justify-content:space-between;align-items:start;\" data-kid=\"74\">\n          <i class=\"ti ti-browser\" style=\"font-size:2rem;color:var(--muted2);\" data-kid=\"75\"></i>\n          <span style=\"font-size:0.7rem;color:var(--muted);letter-spacing:0.1em;\" data-kid=\"76\">01</span>\n        </div>\n        <div data-kid=\"77\">\n          <h3 style=\"font-size:1.5rem;font-weight:700;margin:0 0 12px;letter-spacing:-0.02em;\" data-kid=\"78\">Landing Page</h3>\n          <p style=\"font-size:0.875rem;color:var(--muted2);line-height:1.7;margin:0;\" data-kid=\"79\">Páginas de conversión únicas con animaciones, diseño responsive y hasta 4 secciones adicionales. El plan más contratado.</p>\n        </div>\n        <div style=\"margin-top:auto;padding-top:24px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;\" data-kid=\"80\">\n          <span style=\"font-size:0.75rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em;\" data-kid=\"81\">Desde $799 USD</span>\n          <i class=\"ti ti-arrow-up-right\" style=\"color:var(--muted);\" data-kid=\"82\"></i>\n        </div>\n      </div>\n\n      \n      <div class=\"svc-card\" style=\"background:var(--bg);padding:48px;display:flex;flex-direction:column;gap:24px;cursor:default;\" data-reveal data-kid=\"83\">\n        <div style=\"display:flex;justify-content:space-between;align-items:start;\" data-kid=\"84\">\n          <i class=\"ti ti-file-description\" style=\"font-size:2rem;color:var(--muted2);\" data-kid=\"85\"></i>\n          <span style=\"font-size:0.7rem;color:var(--muted);letter-spacing:0.1em;\" data-kid=\"86\">02</span>\n        </div>\n        <div data-kid=\"87\">\n          <h3 style=\"font-size:1.5rem;font-weight:700;margin:0 0 12px;letter-spacing:-0.02em;\" data-kid=\"88\">Página Informativa</h3>\n          <p style=\"font-size:0.875rem;color:var(--muted2);line-height:1.7;margin:0;\" data-kid=\"89\">Sitio web para tu negocio o servicio con diseño profesional, formulario de contacto e integración con redes sociales.</p>\n        </div>\n        <div style=\"margin-top:auto;padding-top:24px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;\" data-kid=\"90\">\n          <span style=\"font-size:0.75rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em;\" data-kid=\"91\">Desde $399 USD</span>\n          <i class=\"ti ti-arrow-up-right\" style=\"color:var(--muted);\" data-kid=\"92\"></i>\n        </div>\n      </div>\n\n      \n      <div class=\"svc-card\" style=\"background:var(--bg);padding:48px;display:flex;flex-direction:column;gap:24px;cursor:default;\" data-reveal data-kid=\"93\">\n        <div style=\"display:flex;justify-content:space-between;align-items:start;\" data-kid=\"94\">\n          <i class=\"ti ti-shopping-bag\" style=\"font-size:2rem;color:var(--muted2);\" data-kid=\"95\"></i>\n          <span style=\"font-size:0.7rem;color:var(--muted);letter-spacing:0.1em;\" data-kid=\"96\">03</span>\n        </div>\n        <div data-kid=\"97\">\n          <h3 style=\"font-size:1.5rem;font-weight:700;margin:0 0 12px;letter-spacing:-0.02em;\" data-kid=\"98\">E-commerce</h3>\n          <p style=\"font-size:0.875rem;color:var(--muted2);line-height:1.7;margin:0;\" data-kid=\"99\">Tienda online con WooCommerce, diseño personalizado, ingreso de productos, SEO y pasarela de pagos configurada.</p>\n        </div>\n        <div style=\"margin-top:auto;padding-top:24px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;\" data-kid=\"100\">\n          <span style=\"font-size:0.75rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em;\" data-kid=\"101\">Desde $1.299 USD</span>\n          <i class=\"ti ti-arrow-up-right\" style=\"color:var(--muted);\" data-kid=\"102\"></i>\n        </div>\n      </div>\n\n      \n      <div class=\"svc-card\" style=\"background:var(--bg);padding:48px;display:flex;flex-direction:column;gap:24px;cursor:default;\" data-reveal data-kid=\"103\">\n        <div style=\"display:flex;justify-content:space-between;align-items:start;\" data-kid=\"104\">\n          <i class=\"ti ti-terminal-2\" style=\"font-size:2rem;color:var(--muted2);\" data-kid=\"105\"></i>\n          <span style=\"font-size:0.7rem;color:var(--muted);letter-spacing:0.1em;\" data-kid=\"106\">04</span>\n        </div>\n        <div data-kid=\"107\">\n          <h3 style=\"font-size:1.5rem;font-weight:700;margin:0 0 12px;letter-spacing:-0.02em;\" data-kid=\"108\">Sistemas Web</h3>\n          <p style=\"font-size:0.875rem;color:var(--muted2);line-height:1.7;margin:0;\" data-kid=\"109\">Desarrollo de sistemas personalizados, integraciones API, dashboards y aplicaciones web complejas a medida.</p>\n        </div>\n        <div style=\"margin-top:auto;padding-top:24px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;\" data-kid=\"110\">\n          <span style=\"font-size:0.75rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em;\" data-kid=\"111\">Cotizar</span>\n          <i class=\"ti ti-arrow-up-right\" style=\"color:var(--muted);\" data-kid=\"112\"></i>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section id=\"sobre-mi\" style=\"padding:120px 48px;background:var(--surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border);\" data-kid=\"113\">\n  <div style=\"max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;\" data-kid=\"114\">\n    <div data-reveal data-kid=\"115\">\n      <span style=\"font-size:0.7rem;text-transform:uppercase;letter-spacing:0.2em;color:var(--muted);display:block;margin-bottom:24px;\" data-kid=\"116\">Sobre mí</span>\n      <h2 style=\"font-si