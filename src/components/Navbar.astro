---
import AeLogo from './AeLogo.astro';
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 w-full z-50 px-6 py-5 flex justify-between items-center transition-all duration-300"
  style="background: linear-gradient(to bottom, rgba(17,17,17,0.95) 0%, transparent 100%); backdrop-filter: blur(8px);"
>
  <a href="#" class="flex items-center gap-3 group relative z-10">
    <AeLogo width={48} height={32} class="text-white" />
    <div>
      <div class="font-anton text-lg uppercase tracking-tighter leading-none">
        Anderson <span class="text-(--color-gold)">Espinoza</span>
      </div>
      <div class="text-[9px] uppercase tracking-[0.35em] opacity-40 font-bold">
        DevAE · Dev Agency
      </div>
    </div>
  </a>

  <!-- Desktop links -->
  <div class="hidden md:flex gap-8 items-center text-xs uppercase tracking-widest font-bold">
    <a href="#services" class="hover:text-(--color-gold) transition-colors">Servicios</a>
    <a href="#tech" class="hover:text-(--color-gold) transition-colors">Tecnología</a>
    <a href="#portfolio" class="hover:text-(--color-gold) transition-colors">Portfolio</a>
    <a
      href="#contact"
      class="px-6 py-2 border border-white/20 hover:border-(--color-gold) hover:text-(--color-gold) transition-colors"
    >
      Contacto
    </a>
  </div>

  <!-- Mobile menu button -->
  <button
    id="mobile-menu-btn"
    class="md:hidden w-10 h-10 flex items-center justify-center border border-white/20 text-white relative z-10"
    aria-label="Abrir menú"
    aria-expanded="false"
    aria-controls="mobile-menu"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="3" y1="6" x2="21" y2="6"></line>
      <line x1="3" y1="12" x2="21" y2="12"></line>
      <line x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
  </button>

  <!-- Mobile menu overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-(--color-onyx)/98 backdrop-blur-lg flex-col items-center justify-center gap-8 md:hidden"
    style="display: none;"
  >
    <button
      id="mobile-menu-close"
      class="absolute top-6 right-6 w-10 h-10 flex items-center justify-center border border-white/20 text-white"
      aria-label="Cerrar menú"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <a href="#services" class="text-sm uppercase tracking-widest font-bold hover:text-(--color-gold) transition-colors">Servicios</a>
    <a href="#tech" class="text-sm uppercase tracking-widest font-bold hover:text-(--color-gold) transition-colors">Tecnología</a>
    <a href="#portfolio" class="text-sm uppercase tracking-widest font-bold hover:text-(--color-gold) transition-colors">Portfolio</a>
    <a href="#contact" class="px-6 py-2 border border-white/20 hover:border-(--color-gold) hover:text-(--color-gold) transition-colors text-sm uppercase tracking-widest font-bold">
      Contacto
    </a>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menuClose = document.getElementById('mobile-menu-close');
  const mobileMenu = document.getElementById('mobile-menu');
  let isOpen = false;

  function toggleMenu(open: boolean) {
    isOpen = open;
    if (mobileMenu) {
      mobileMenu.style.display = open ? 'flex' : 'none';
    }
    if (menuBtn) {
      menuBtn.setAttribute('aria-expanded', String(open));
    }
  }

  menuBtn?.addEventListener('click', () => toggleMenu(!isOpen));
  menuClose?.addEventListener('click', () => toggleMenu(false));

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => toggleMenu(false));
  });

  window.addEventListener('scroll', () => {
    if (!nav) return;
    if (window.scrollY > 80) {
      nav.style.background = 'rgba(17,17,17,0.97)';
      nav.style.borderBottom = '1px solid rgba(255,255,255,0.05)';
    } else {
      nav.style.background = 'linear-gradient(to bottom, rgba(17,17,17,0.95) 0%, transparent 100%)';
      nav.style.borderBottom = '1px solid transparent';
    }
  }, { passive: true });
</script>
