---
import Icon from './Icon.astro';

const projects = [
  {
    id: 1,
    title: 'Tienda WooCommerce',
    category: 'E-commerce',
    tags: 'E-commerce / WordPress / WooCommerce',
    image: '/projects/ecommerce.png',
    label: 'E-commerce\nStore',
    wide: true,
    aspect: 'aspect-[21/9]',
  },
  {
    id: 2,
    title: 'Landing de Alta Conversión',
    category: 'Landing',
    tags: 'Landing Page / Diseño / Conversión',
    image: '/projects/landing.png',
    label: 'Landing\nPage',
    wide: false,
    aspect: 'aspect-[4/5]',
  },
  {
    id: 3,
    title: 'Plugin Personalizado',
    category: 'Plugin',
    tags: 'WordPress Plugin / Integración / API',
    image: '/projects/plugin.png',
    label: 'WP\nPlugin',
    wide: false,
    aspect: 'aspect-square',
  },
  {
    id: 4,
    title: 'Sitio Corporativo',
    category: 'Corporativo',
    tags: 'Página Informativa / Branding / SEO',
    image: '/projects/corporate.png',
    label: 'Sitio\nCorporativo',
    wide: true,
    aspect: 'aspect-[16/7]',
  },
];
---

<section id="portfolio" class="py-20 md:py-40 bg-(--color-onyx) px-4 sm:px-6">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 md:mb-24 gap-6 md:gap-8">
      <div class="reveal-portfolio">
        <span class="text-(--color-gold) text-sm font-bold uppercase tracking-[0.4em] block mb-4">Portafolio Seleccionado</span>
        <h2 class="font-anton text-4xl sm:text-6xl md:text-8xl lg:text-9xl uppercase leading-[0.85] md:leading-[0.8]">
          Proyectos<br />Realizados
        </h2>
      </div>
      <div class="reveal-portfolio flex flex-wrap gap-2" id="portfolio-filters">
        <button data-filter="all" class="filter-btn px-5 md:px-8 py-2 border-2 border-(--color-gold) text-(--color-gold) text-xs uppercase font-black transition-all">
          Todos
        </button>
        <button data-filter="E-commerce" class="filter-btn px-5 md:px-8 py-2 border-2 border-white/10 text-white/40 text-xs uppercase font-black hover:border-(--color-gold) hover:text-(--color-gold) transition-all">
          E-commerce
        </button>
        <button data-filter="Landing" class="filter-btn px-5 md:px-8 py-2 border-2 border-white/10 text-white/40 text-xs uppercase font-black hover:border-(--color-gold) hover:text-(--color-gold) transition-all">
          Landing
        </button>
        <button data-filter="Plugin" class="filter-btn px-5 md:px-8 py-2 border-2 border-white/10 text-white/40 text-xs uppercase font-black hover:border-(--color-gold) hover:text-(--color-gold) transition-all">
          Plugins
        </button>
        <button data-filter="Corporativo" class="filter-btn px-5 md:px-8 py-2 border-2 border-white/10 text-white/40 text-xs uppercase font-black hover:border-(--color-gold) hover:text-(--color-gold) transition-all">
          Corporativo
        </button>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8" id="portfolio-grid">
      {projects.map((p) => (
        <div
          class={`reveal-portfolio portfolio-item group ${p.wide ? 'col-span-1 md:col-span-8' : 'col-span-1 md:col-span-4'}`}
          data-category={p.category}
          style="cursor:pointer"
        >
          <div class={`${p.aspect} bg-(--color-jet) brutalist-border crosshatch overflow-hidden relative`}>
            <div class="absolute inset-0 bg-neutral-900 z-10 flex items-center justify-center pointer-events-none group-hover:opacity-0 transition-opacity duration-700">
              <span class="font-anton text-3xl md:text-5xl uppercase opacity-20 tracking-tighter whitespace-pre-line text-center">
                {p.label}
              </span>
            </div>
            <img
              src={p.image}
              alt={p.title}
              class="portfolio-reveal absolute inset-0 w-full h-full object-cover grayscale transition-transform duration-700"
              decoding="async"
              loading="lazy"
            />
            <div class="absolute inset-0 border-4 border-(--color-gold)/0 group-hover:border-(--color-gold)/30 transition-all duration-700 z-20 pointer-events-none"></div>
          </div>
          <div class="mt-4 md:mt-8 flex flex-col md:flex-row justify-between items-start gap-3 md:gap-4">
            <div>
              <h4 class="font-anton text-xl md:text-4xl uppercase leading-tight">{p.title}</h4>
              <p class="text-xs md:text-sm uppercase font-bold tracking-[0.3em] text-(--color-gold) mt-1 md:mt-2">{p.tags}</p>
            </div>
            {p.wide && (
              <div class="flex items-center gap-3 md:gap-4 text-(--color-gold)">
                <span class="font-anton text-base md:text-xl uppercase">Ver Proyecto</span>
                <Icon name="ArrowRight" class="text-xl md:text-3xl" />
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.portfolio-item');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');

      filterBtns.forEach((b) => {
        if (b === btn) {
          b.classList.add('border-(--color-gold)', 'text-(--color-gold)');
          b.classList.remove('border-white/10', 'text-white/40');
        } else {
          b.classList.remove('border-(--color-gold)', 'text-(--color-gold)');
          b.classList.add('border-white/10', 'text-white/40');
        }
      });

      items.forEach((item) => {
        const category = item.getAttribute('data-category');
        if (filter === 'all' || category === filter) {
          (item as HTMLElement).style.display = 'block';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
