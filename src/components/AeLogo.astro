---
interface Props {
  width?: number;
  height?: number;
  class?: string;
}

const { width = 48, height = 32, class: className = '' } = Astro.props;
---

<svg
  class={`ae-logo-svg ${className}`}
  width={width}
  height={height}
  viewBox="0 0 48 32"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="DevAE logo"
>
  <path d="M2 30L14 2H20L8 30H2Z" fill="currentColor"></path>
  <path d="M12 30L24 2H30L18 30H12Z" fill="#D4AF37"></path>
  <path d="M28 30V2H46V7H34V13H44V18H34V25H46V30H28Z" fill="currentColor"></path>
</svg>
