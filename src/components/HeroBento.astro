---
import Icon from './Icon.astro';
---

<section id="dashboard-bento" class="min-h-screen pt-24 pb-10 px-4 sm:px-6 flex flex-col justify-center">
  <div class="grid grid-cols-1 md:grid-cols-12 md:grid-rows-6 gap-3 md:gap-4 min-h-[85vh] md:h-[85vh]">
    <!-- Main headline tile -->
    <div class="reveal-hero col-span-1 md:col-span-8 md:row-span-4 bg-(--color-jet) p-7 md:p-12 brutalist-border flex flex-col justify-between relative overflow-hidden group">
      <div class="absolute -top-24 -right-24 w-64 h-64 bg-(--color-gold)/5 blur-3xl rounded-full"></div>
      <div class="relative z-10 flex flex-col md:flex-row justify-between items-start gap-4 md:gap-6">
        <h1 class="font-anton text-[clamp(2.5rem,8vw,7.5rem)] uppercase leading-[0.85] tracking-tighter" id="hero-headline">
          WordPress &<br />Desarrollo Web<span class="cursor"></span>
        </h1>
        <Icon name="Code2" class="text-5xl md:text-7xl text-(--color-gold) drop-shadow-[0_0_10px_rgba(212,175,55,0.3)]" />
      </div>
      <div class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-end gap-4 md:gap-6 mt-6 md:mt-0">
        <p class="text-base md:text-xl max-w-lg opacity-60 leading-relaxed font-light">
          Diseño y desarrollo de landing pages de alta conversión, tiendas online, sitios corporativos y plugins o integraciones a medida.
        </p>
        <div class="text-xs uppercase tracking-widest opacity-40 font-bold border-t border-white/10 pt-3 md:pt-4">
          [ WordPress & Custom Specialist ] / DevAE
        </div>
      </div>
    </div>

    <!-- Plugins & APIs tile -->
    <div class="reveal-hero col-span-1 md:col-span-4 md:row-span-2 bg-(--color-jet) brutalist-border flex flex-col justify-between p-6 md:p-8 overflow-hidden relative group min-h-[180px] md:min-h-[200px]">
      <div class="absolute inset-0 bg-gradient-to-br from-(--color-gold)/5 to-transparent"></div>
      <div class="relative z-10 flex justify-between items-start">
        <Icon name="Puzzle" class="text-3xl md:text-4xl text-(--color-gold) transition-transform duration-500 group-hover:rotate-12" />
        <span class="text-[10px] font-bold uppercase tracking-widest opacity-30">WordPress Core</span>
      </div>
      <div class="relative z-10 mt-3 md:mt-4">
        <h4 class="font-anton text-xl md:text-2xl uppercase leading-none group-hover:text-(--color-gold) transition-colors">Plugins & APIs</h4>
        <p class="text-xs opacity-50 mt-2 leading-relaxed">
          Desarrollo de plugins a medida, complementos exclusivos y conexiones de sistemas externos.
        </p>
      </div>
    </div>

    <!-- Performance & SEO tile -->
    <div class="reveal-hero col-span-1 md:col-span-4 md:row-span-2 bg-(--color-jet) brutalist-border p-6 md:p-8 flex flex-col justify-between relative overflow-hidden min-h-[180px] md:min-h-[200px] group">
      <div class="absolute top-0 left-0 w-full h-1 bg-(--color-gold)/20"></div>
      <div class="relative z-10 flex justify-between items-start">
        <Icon name="Gauge" class="text-3xl md:text-4xl text-(--color-gold) transition-transform duration-500 group-hover:scale-110" />
        <span class="text-[10px] font-bold uppercase tracking-widest opacity-30">Rendimiento</span>
      </div>
      <div class="relative z-10">
        <div class="flex items-baseline gap-1">
          <span class="text-5xl md:text-6xl font-anton text-(--color-gold) leading-none" id="latency-counter">99</span>
          <span class="text-2xl font-anton text-(--color-gold) leading-none">%</span>
        </div>
        <span class="text-xs uppercase tracking-widest mt-2 block opacity-50 font-bold">Lighthouse Score & SEO</span>
      </div>
    </div>

    <!-- CTA tile -->
    <a href="#contact" class="reveal-hero col-span-1 md:col-span-4 md:row-span-2 bg-(--color-gold) text-black p-7 md:p-10 flex flex-col justify-between group min-h-[180px] md:min-h-[200px] transition-transform duration-300 hover:scale-[1.01]">
      <div class="flex justify-between items-start">
        <h3 class="font-anton text-3xl md:text-4xl uppercase leading-none">Inicia tu<br />proyecto</h3>
        <Icon name="ArrowUpRight" class="text-4xl md:text-5xl" />
      </div>
      <div class="flex items-center gap-3 md:gap-4 text-xs font-bold uppercase tracking-widest border-t border-black/10 pt-5 md:pt-6">
        <span class="w-2 h-2 bg-black rounded-full animate-ping"></span>
        Disponibilidad inmediata
      </div>
    </a>

    <!-- Niche services row -->
    <div class="reveal-hero col-span-1 md:col-span-8 md:row-span-2 brutalist-border flex flex-col md:flex-row items-stretch px-6 md:px-8 py-6 md:py-8 gap-5 md:gap-8 relative bg-(--color-jet)">
      <div class="flex-1 flex flex-col justify-between gap-2">
        <div>
          <span class="text-xs uppercase text-(--color-gold)/60 font-bold tracking-[0.2em]">01 / CMS</span>
          <span class="font-anton text-lg md:text-xl uppercase block mt-1">WordPress & WooCommerce</span>
        </div>
        <p class="text-xs opacity-50 leading-relaxed">Sitios autogestionables, tiendas online y plantillas desde cero sin maquetadores pesados.</p>
      </div>
      <div class="hidden md:block w-px bg-white/10 self-stretch"></div>
      <div class="flex-1 flex flex-col justify-between gap-2">
        <div>
          <span class="text-xs uppercase text-(--color-gold)/60 font-bold tracking-[0.2em]">02 / Growth</span>
          <span class="font-anton text-lg md:text-xl uppercase block mt-1">Landings & Webs Corporativas</span>
        </div>
        <p class="text-xs opacity-50 leading-relaxed">Diseños de conversión optimizados para campañas y portales web rápidos para tu marca.</p>
      </div>
      <div class="hidden md:block w-px bg-white/10 self-stretch"></div>
      <div class="flex-1 flex flex-col justify-between gap-2">
        <div>
          <span class="text-xs uppercase text-(--color-gold)/60 font-bold tracking-[0.2em]">03 / Custom</span>
          <span class="font-anton text-lg md:text-xl uppercase block mt-1">Sistemas & APIs a Medida</span>
        </div>
        <p class="text-xs opacity-50 leading-relaxed">Desarrollo a medida con tecnologías modernas para proyectos que requieren lógica compleja.</p>
      </div>
    </div>
  </div>
</section>
