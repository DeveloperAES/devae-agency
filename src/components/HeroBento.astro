---
import Icon from "./Icon.astro";
---

<section
  id="dashboard-bento"
  class="relative min-h-screen pt-20 pb-0 px-4 sm:px-6 lg:px-12 flex flex-col justify-center overflow-hidden"
>
  <!-- Diffused global glow -->
  <div
    class="absolute inset-0 z-0 pointer-events-none flex items-center justify-center opacity-30"
  >
    <div
      class="w-[80vw] h-[80vw] max-w-[800px] max-h-[800px] bg-(--color-gold) blur-[120px] rounded-full transform translate-x-1/4"
    >
    </div>
  </div>

  <!-- Main two-column hero -->
  <div
    class="relative z-10 max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-0 items-center min-h-[90vh]"
  >
    <!-- LEFT: Text content -->
    <div class="reveal-hero flex flex-col gap-8 lg:pr-12 pt-8 lg:pt-0">
      <!-- Badge -->
      <div class="inline-flex items-center gap-3 self-start">
        <span class="w-2 h-2 bg-(--color-gold) rounded-full animate-pulse"
        ></span>
        <span class="text-xs font-bold uppercase tracking-[0.3em] opacity-50"
          >Disponible para nuevos proyectos</span
        >
      </div>

      <!-- Headline -->
      <h1
        class="font-anton text-[clamp(3rem,8vw,6.5rem)] uppercase leading-[0.9] tracking-tighter"
        id="hero-headline"
      >
        Tu negocio,<br />
        <span class="text-(--color-gold)">online</span><br />
        y vendiendo.
      </h1>

      <!-- Subtitle -->
      <p
        class="text-lg lg:text-xl opacity-60 leading-relaxed max-w-md font-light"
      >
        Creamos tu página web para que atraiga clientes, genere ventas y trabaje
        por ti — sin que tengas que entender nada de tecnología.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="#contact"
          id="hero-cta-primary"
          class="inline-flex items-center justify-center gap-3 bg-(--color-gold) text-black font-bold uppercase tracking-widest text-sm px-8 py-4 transition-all duration-300 hover:bg-white group"
        >
          Quiero mi web ahora
          <Icon
            name="ArrowRight"
            class="text-base transition-transform group-hover:translate-x-1"
          />
        </a>
        <a
          href="#portfolio"
          id="hero-cta-secondary"
          class="inline-flex items-center justify-center gap-3 border border-white/20 text-white font-bold uppercase tracking-widest text-sm px-8 py-4 transition-all duration-300 hover:border-(--color-gold) hover:text-(--color-gold)"
        >
          Ver proyectos
        </a>
      </div>

      <!-- Social proof bar -->
      <div
        class="flex items-center gap-8 pt-4 border-t border-white/10"
        id="stats-container"
      >
        <div class="flex flex-col">
          <div class="flex items-baseline">
            <span
              class="font-anton text-3xl text-(--color-gold) leading-none stat-number"
              data-target="99">0</span
            >
            <span class="font-anton text-3xl text-(--color-gold) leading-none"
              >%</span
            >
          </div>
          <span
            class="text-[10px] uppercase tracking-widest opacity-40 font-bold mt-1"
            >Velocidad en Google</span
          >
        </div>
        <div class="w-px h-10 bg-white/10"></div>
        <div class="flex flex-col">
          <div class="flex items-baseline">
            <span class="font-anton text-3xl text-(--color-gold) leading-none"
              >+</span
            >
            <span
              class="font-anton text-3xl text-(--color-gold) leading-none stat-number"
              data-target="20">0</span
            >
          </div>
          <span
            class="text-[10px] uppercase tracking-widest opacity-40 font-bold mt-1"
            >Proyectos entregados</span
          >
        </div>
        <div class="w-px h-10 bg-white/10"></div>
        <div class="flex flex-col">
          <div class="flex items-baseline">
            <span
              class="font-anton text-3xl text-(--color-gold) leading-none stat-number"
              data-target="24">0</span
            >
            <span class="font-anton text-3xl text-(--color-gold) leading-none"
              >h</span
            >
          </div>
          <span
            class="text-[10px] uppercase tracking-widest opacity-40 font-bold mt-1"
            >Tiempo de respuesta</span
          >
        </div>
      </div>
    </div>

    <!-- RIGHT: Visual / mockup carousel -->
    <div
      class="reveal-hero relative flex items-center justify-center lg:justify-end h-[50vw] lg:h-full min-h-[320px] lg:min-h-0 perspective-[1000px]"
    >
      <!-- Image Carousel Container -->
      <div
        class="relative w-full max-w-xl lg:max-w-none lg:w-[120%] lg:-mr-20 h-full flex items-center justify-center image-mask"
      >
        <img
          src="/hero-devices.png"
          class="hero-carousel-img absolute inset-0 w-full h-full object-contain object-center transition-opacity duration-1000 opacity-100"
        />
        <img
          src="/hero-carousel-1.png"
          class="hero-carousel-img absolute inset-0 w-full h-full object-contain object-center transition-opacity duration-1000 opacity-0"
        />
        <img
          src="/hero-carousel-2.png"
          class="hero-carousel-img absolute inset-0 w-full h-full object-contain object-center transition-opacity duration-1000 opacity-0"
        />
      </div>

      <!-- Floating badge -->
      <div
        class="absolute top-4 right-4 lg:top-8 lg:right-0 z-20 bg-(--color-jet)/80 backdrop-blur-md border border-white/10 px-5 py-3 flex items-center gap-3 rounded-sm shadow-xl"
      >
        <Icon name="Star" class="text-(--color-gold) text-lg animate-pulse" />
        <div>
          <div class="font-anton text-lg leading-none text-white">
            +3 proyectos
          </div>
          <div
            class="text-[10px] uppercase tracking-widest text-white/50 mt-0.5"
          >
            En el portafolio
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom scrolling services strip -->
  <!-- <div class="relative z-10 w-full border-t border-white/5 mt-auto py-5 overflow-hidden bg-transparent">
    <div class="flex items-center gap-12 animate-marquee whitespace-nowrap opacity-30 text-xs font-bold uppercase tracking-[0.3em]">
