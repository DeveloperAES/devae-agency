      <span class="text-(--color-gold)">·</span>
      <span>WooCommerce</span>
      <span class="text-(--color-gold)">·</span>
    </div>
  </div> -->
</section>

<style>
  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
  .animate-marquee {
    animation: marquee 20s linear infinite;
  }

  /* Blends the square edges of the images smoothly into the background */
  .image-mask {
    -webkit-mask-image: radial-gradient(
      circle at center,
      rgba(0, 0, 0, 1) 35%,
      rgba(0, 0, 0, 0) 65%
    );
    mask-image: radial-gradient(
      circle at center,
      rgba(0, 0, 0, 1) 35%,
      rgba(0, 0, 0, 0) 65%
    );
  }

  .hero-carousel-img {
    mix-blend-mode: lighten;
  }
</style>

<script>
  // Setup Carousel
  const images = document.querySelectorAll(".hero-carousel-img");
  let currentImage = 0;

  if (images.length > 1) {
    setInterval(() => {
      images[currentImage].classList.remove("opacity-100");
      images[currentImage].classList.add("opacity-0");

      currentImage = (currentImage + 1) % images.length;

      images[currentImage].classList.remove("opacity-0");
      images[currentImage].classList.add("opacity-100");
    }, 4000); // Change image every 4 seconds
  }

  // Setup Number Counters
  const statsSection = document.getElementById("stats-container");
  const numbers = document.querySelectorAll(".stat-number");
  let animated = false;

  const animateNumbers = () => {
    numbers.forEach((num) => {
      const target = parseInt(num.getAttribute("data-target") || "0", 10);
      const duration = 2000; // 2 seconds
      const stepTime = Math.abs(Math.floor(duration / target));
      let current = 0;

      const timer = setInterval(() => {
        current += 1;
        num.textContent = current.toString();
        if (current >= target) {
          clearInterval(timer);
          num.textContent = target.toString();
        }
      }, stepTime);
    });
  };

  if (statsSection) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting && !animated) {
          animated = true;
          animateNumbers();
        }
      },
      { threshold: 0.5 },
    );

    observer.observe(statsSection);
  }
</script>
