---
import Icon from './Icon.astro';

const services = [
  {
    num: '01',
    icon: 'MonitorSmartphone',
    title: 'Landing\nPages',
    desc: 'Estructuras de conversión optimizadas para tráfico de alta densidad.',
  },
  {
    num: '02',
    icon: 'BookOpen',
    title: 'Portales\nMarca',
    desc: 'Sitios informativos con autoridad visual y narrativa técnica impecable.',
  },
  {
    num: '03',
    icon: 'ShoppingCart',
    title: 'E-commerce\nEnterprise',
    desc: 'Infraestructuras transaccionales masivas, integraciones ERP/CRM y checkout personalizado sin fricciones.',
    tags: ['WooCommerce', 'Shopify Plus'],
    wide: true,
  },
];
---

<section id="services" class="py-24 md:py-32 px-4 sm:px-6 bg-(--color-onyx)">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start mb-16 md:mb-24">
      <div class="col-span-1 md:col-span-8 reveal-service">
        <span class="text-(--color-gold) text-sm font-bold uppercase tracking-[0.4em] block mb-4">// Arquitectura Modular</span>
        <h2 class="font-anton text-5xl md:text-7xl lg:text-8xl uppercase leading-[0.9]">
          Bloques Digitales de Alta Performance
        </h2>
      </div>
      <div class="col-span-1 md:col-span-4 reveal-service flex flex-col gap-6 pt-0 md:pt-12">
        <p class="text-lg opacity-50 leading-relaxed">
          No construimos sitios web; forjamos infraestructuras de negocio que combinan la rigidez arquitectónica con la flexibilidad del software moderno.
        </p>
        <div class="h-px w-24 bg-(--color-gold)"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-1 border-t border-white/10 pt-1">
      {services.map((s) => (
        <div
          class={`reveal-service bg-(--color-jet) p-8 md:p-12 flex flex-col min-h-[320px] md:min-h-[400px] justify-between group ${
            s.wide ? 'col-span-1 md:col-span-6 relative overflow-hidden' : 'col-span-1 md:col-span-3'
          }`}
        >
          {s.wide && (
            <div class="absolute -right-12 -bottom-12 opacity-[0.03] group-hover:opacity-[0.08] transition-opacity">
              <Icon name="ShoppingCart" class="text-[10rem] md:text-[16rem] text-white" />
            </div>
          )}
          <div class="flex justify-between items-start">
            <Icon name={s.icon as any} class="text-3xl md:text-4xl text-(--color-gold)" />
            <span class="text-xs font-bold opacity-30">{s.num}</span>
          </div>
          <div class={s.wide ? 'max-w-md' : ''}>
            <h3 class="font-anton text-2xl md:text-3xl lg:text-5xl uppercase mb-4 md:mb-6 group-hover:text-(--color-gold) transition-colors whitespace-pre-line">
              {s.title}
            </h3>
            <p class={`text-sm opacity-60 leading-relaxed ${s.wide ? 'mb-6' : 'uppercase tracking-widest leading-loose opacity-50'}`}>
              {s.desc}
            </p>
            {s.tags && (
              <div class="flex flex-wrap gap-3">
                {s.tags.map((tag) => (
                  <span class="text-xs px-3 py-1 border border-(--color-gold)/20 text-(--color-gold)/60 font-bold uppercase tracking-widest">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}

      <div class="reveal-service col-span-1 md:col-span-12 bg-(--color-jet) p-8 md:p-16 flex flex-col md:flex-row items-start md:items-center justify-between group mt-1 corner-bracket">
        <span></span>
        <div class="flex flex-col gap-6 md:w-1/2">
          <div class="flex items-center gap-6">
            <Icon name="Database" class="text-4xl md:text-5xl text-(--color-gold)" />
            <span class="text-xs font-bold opacity-30 uppercase tracking-[0.5em]">Systems Engineering</span>
          </div>
          <h3 class="font-anton text-4xl md:text-5xl lg:text-6xl uppercase leading-none group-hover:text-(--color-gold) transition-colors">
            Arquitectura de Sistemas & APIs
          </h3>
        </div>
        <div class="md:w-1/3 flex flex-col gap-6 pt-8 md:pt-0">
          <p class="text-sm opacity-60 leading-relaxed uppercase tracking-widest">
            Desarrollo de backends robustos, dashboards de gestión críticos y ecosistemas de microservicios escalables.
          </p>
          <div class="flex gap-4 items-center text-(--color-gold)">
            <span class="font-anton text-lg md:text-xl uppercase">Ver Documentación Técnica</span>
            <Icon name="ArrowRight" class="text-2xl" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
