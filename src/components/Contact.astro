---
import Icon from "./Icon.astro";
import AeLogoBg from "./AeLogoBg.astro";
---

<section
  id="contact"
  class="py-24 lg:py-40 bg-(--color-onyx) px-4 sm:px-6 relative overflow-hidden"
>
  <div
    class="absolute right-0 top-1/2 -translate-y-1/2 pointer-events-none opacity-[0.025]"
  >
    <AeLogoBg />
  </div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      <!-- Contact info -->
      <div class="col-span-1 lg:col-span-5 lg:sticky lg:top-32">
        <div class="reveal-contact">
          <span
            class="text-(--color-gold) text-sm font-bold uppercase tracking-[0.4em] block mb-6"
            >// Iniciar Proyecto</span
          >
          <h2
            class="font-anton text-5xl md:text-7xl uppercase leading-[1.1] lg:leading-[0.85] mb-12"
          >
            Hablemos<br />de tu<br /><span class="text-(--color-gold)"
              >Proyecto</span
            >
          </h2>
        </div>
        <div
          class="reveal-contact flex flex-col gap-10 border-t border-white/10 pt-12"
        >
          <div>
            <span
              class="text-(--color-gold) text-xs font-bold uppercase tracking-widest block mb-3"
              >Email</span
            >
            <p class="text-lg md:text-xl font-medium tracking-wide mt-1">
              <a
                href="mailto:aespinozaanco38@gmail.com"
                class="hover:text-(--color-gold) transition-colors"
              >
                aespinozaanco38@gmail.com
              </a>
            </p>
          </div>
          <div>
            <span
              class="text-(--color-gold) text-xs font-bold uppercase tracking-widest block mb-3"
              >WhatsApp / Telegram</span
            >
            <p class="text-lg md:text-xl font-medium tracking-wide mt-1">
              <a
                href="https://wa.me/51991145635?text=Hola,%20me%20gustar%C3%ADa%20cotizar%20un%20proyecto."
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-(--color-gold) transition-colors"
              >
                +51 991 145 635
              </a>
            </p>
          </div>
          <div>
            <span
              class="text-(--color-gold) text-xs font-bold uppercase tracking-widest block mb-3"
              >Basado en</span
            >
            <p class="text-lg md:text-xl font-medium tracking-wide mt-1">
              Latinoamérica · Global
            </p>
          </div>
          <div class="flex gap-4 pt-4">
            <a
              href="#"
              class="w-12 h-12 flex items-center justify-center border border-white/10 hover:border-(--color-gold) hover:text-(--color-gold) transition-colors"
              aria-label="LinkedIn"
            >
              <svg
                viewBox="0 0 24 24"
                width="20"
                height="20"
                stroke="currentColor"
                stroke-width="1.5"
                fill="none"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                ></path><rect x="2" y="9" width="4" height="12"></rect><circle
                  cx="4"
                  cy="4"
                  r="2"></circle></svg
              >
            </a>
            <a
              href="#"
              class="w-12 h-12 flex items-center justify-center border border-white/10 hover:border-(--color-gold) hover:text-(--color-gold) transition-colors"
              aria-label="GitHub"
            >
              <svg
                viewBox="0 0 24 24"
                width="20"
                height="20"
                stroke="currentColor"
                stroke-width="1.5"
                fill="none"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
                ></path></svg
              >
            </a>
            <a
              href="#"
              class="w-12 h-12 flex items-center justify-center border border-white/10 hover:border-(--color-gold) hover:text-(--color-gold) transition-colors"
              aria-label="X / Twitter"
            >
              <svg
                viewBox="0 0 24 24"
                width="20"
                height="20"
                stroke="currentColor"
                stroke-width="1.5"
                fill="none"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M4 4l11.733 16h4.267l-11.733 -16z"></path><path
                  d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"></path></svg
              >
            </a>
            <a
              href="#"
              class="w-12 h-12 flex items-center justify-center border border-white/10 hover:border-(--color-gold) hover:text-(--color-gold) transition-colors"
              aria-label="Instagram"
            >
              <svg
                viewBox="0 0 24 24"
                width="20"
                height="20"
                stroke="currentColor"
                stroke-width="1.5"
                fill="none"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"
                ></rect><path
                  d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                ></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"
                ></line></svg
              >
            </a>
          </div>
        </div>
      </div>

      <!-- Contact form -->
      <div class="col-span-1 lg:col-span-7">
        <form
          class="reveal-contact flex flex-col gap-10 lg:gap-12"
          id="contact-form"
          method="POST"
          action="/api/contact"
        >
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="flex flex-col gap-1">
              <label
                class="text-(--color-gold) text-xs font-bold uppercase tracking-widest"
                for="name">Nombre completo</label
              >
              <input
                type="text"
                id="name"
                name="name"
                class="contact-input"
                placeholder="Tu nombre"
                required
              />
            </div>
            <div class="flex flex-col gap-1">
              <label
                class="text-(--color-gold) text-xs font-bold uppercase tracking-widest"
                for="email">Email</label
              >
              <input
                type="email"
                id="email"
                name="email"
                class="contact-input"
                placeholder="tu@email.com"
                required
              />
            </div>
          </div>

          <div class="flex flex-col gap-1 relative">
            <label
              class="text-(--color-gold) text-xs font-bold uppercase tracking-widest"
              for="project">Tipo de proyecto</label
            >
            <select id="project" name="project" class="contact-select" required>
              <option value="" disabled selected>Selecciona un servicio</option>
              <option value="landing">Landing Page</option>
              <option value="informativo">Página Informativa</option>
              <option value="ecommerce">E-commerce</option>
              <option value="sistema">Sistema / Aplicación Web</option>
              <option value="otro">Otro</option>
            </select>
            <Icon
              name="ChevronDown"
              class="absolute right-0 bottom-4 text-(--color-gold)/40 pointer-events-none"
            />
          </div>

          <div class="flex flex-col gap-4">
            <span
              class="text-(--color-gold) text-xs font-bold uppercase tracking-widest"
              >Presupuesto estimado</span
            >
            <div class="flex flex-wrap gap-3" id="budget-options">
              <label class="budget-option">
                <input
                  type="radio"
                  name="budget"
                  value="S/ 550 - S/ 1,000"
                  class="hidden"
                /> S/ 550 – S/ 1,000
              </label>
              <label class="budget-option">
                <input
                  type="radio"
                  name="budget"
                  value="S/ 1,000 - S/ 2,500"
                  class="hidden"
                /> S/ 1,000 – S/ 2,500
              </label>
            </div>
          </div>

          <div class="flex flex-col gap-1">
            <label
              class="text-(--color-gold) text-xs font-bold uppercase tracking-widest"
              for="message">Descripción del proyecto</label
            >
            <textarea
              id="message"
              name="message"
              class="contact-input resize-none"
              rows="5"
              placeholder="Cuéntame sobre tu proyecto, objetivos y plazos..."
              required></textarea>
          </div>

          <div
            class="flex flex-col md:flex-row items-start md:items-center gap-6 md:gap-8"
          >
            <button
              type="submit"
              id="submit-btn"
              class="group px-8 md:px-12 py-4 md:py-5 bg-(--color-gold) text-black font-anton text-xl md:text-2xl uppercase flex items-center gap-4 hover:bg-white transition-colors w-full md:w-auto justify-center"
            >
              Enviar Mensaje
              <Icon
                name="ArrowRight"
                class="text-xl md:text-2xl group-hover:translate-x-2 transition-transform"
              />
            </button>
            <span class="text-xs opacity-30 uppercase tracking-widest"
              >Respondo en &lt;24h</span
            >
          </div>

          <div
            id="form-success"
            class="hidden py-6 md:py-8 px-8 md:px-10 border border-(--color-gold)/30 bg-(--color-gold)/5 flex items-center gap-6"
          >
            <Icon
              name="CircleCheck"
              class="text-3xl md:text-4xl text-(--color-gold)"
            />
            <div>
              <p
                class="font-anton text-xl md:text-2xl uppercase text-(--color-gold)"
              >
                ¡Mensaje Recibido!
              </p>
              <p class="text-sm opacity-60 mt-1">
                Me pondré en contacto contigo en menos de 24 horas.
              </p>
            </div>
          </div>

          <div
            id="form-error"
            class="hidden py-6 px-8 border border-red-500/30 bg-red-500/5 flex items-center gap-6"
          >
            <Icon name="CircleX" class="text-3xl text-red-400" />
            <div>
              <p class="font-anton text-xl uppercase text-red-400">
                Error al enviar
              </p>
              <p class="text-sm opacity-60 mt-1">
                Intenta nuevamente o escríbeme directamente por email.
              </p>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById(
    "contact-form",
  ) as HTMLFormElement | null;
  const budgetOptions = document.querySelectorAll(".budget-option");

  budgetOptions.forEach((label) => {
    const input = label.querySelector("input");
    input?.addEventListener("change", () => {
      budgetOptions.forEach((l) => l.classList.remove("active"));
      if (input.checked) label.classList.add("active");
    });
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const submitBtn = document.getElementById(
      "submit-btn",
    ) as HTMLButtonElement | null;
    const successEl = document.getElementById("form-success");
    const errorEl = document.getElementById("form-error");

    if (!submitBtn) return;
    submitBtn.disabled = true;
    submitBtn.style.opacity = "0.5";

    try {
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      const response = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        submitBtn.style.display = "none";
        successEl?.classList.remove("hidden");
        form.reset();
        budgetOptions.forEach((l) => l.classList.remove("active"));
      } else {
        errorEl?.classList.remove("hidden");
        submitBtn.disabled = false;
        submitBtn.style.opacity = "1";
      }
    } catch {
      errorEl?.classList.remove("hidden");
      submitBtn.disabled = false;
      submitBtn.style.opacity = "1";
    }
  });
</script>
